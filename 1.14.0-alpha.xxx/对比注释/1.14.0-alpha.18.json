      "cache_id": "cinchov", // 优化版/稳定版/强化版指定了ID，用于区分不同配置的缓存。
      "store_dns": true, // 缓存DNS结果，加速启动。
      "store_fakeip": true // 缓存FakeIP映射。
    },
    // 调试与性能 (Debug)
    "debug": {
      // 优化版/稳定版:
      "gc_percent": 50, // Go GC触发的内存增长百分比。默认100。
