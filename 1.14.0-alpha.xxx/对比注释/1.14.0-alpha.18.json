  // ==================================================
  // 路由（Route）配置
  // ==================================================
  "route": {
    "final": "Final", // 最终匹配的出站。精简版为 "♻️ 自动选择"。
    "default_domain_resolver": "alidns-quic", // 路由决策中解析域名的默认DNS。精简版为 "local"。
    "auto_detect_interface": true, // 所有版本均启用。
    "rules": [
      // === 所有版本高度共有的基础规则 ===
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "port": 53 }, // 目标端口为53
          { "protocol": "dns" } // 或协议为dns
        ],
        "action": "hijack-dns" // 劫持所有DNS流量到sing-box内置DNS服务器，防止DNS泄露。
      },
      { "action": "sniff" }, // 开启流量嗅探，识别域名、协议等。精简版无此规则但通常默认开启。
      {
        "type": "logical", // 逻辑与: 拦截QUIC协议443端口的流量，强制使用TCP/HTTP，可能为了更好的代理稳定性。
        "mode": "and",
        "rules": [
          { "protocol": "quic" },
          { "port": 443 }
        ],
        "action": "reject" // 稳定版/强化版有 "method": "drop" 直接丢弃。
      },
      {
        "package_name": [ // 按APP包名路由，精确控制特定APP。
          "com.google.android.youtube", "app.revanced.android.youtube",
          "org.telegram.messenger", "org.telegram.messenger.beta"
        ],
        "outbound": "PROXY" // 精简版无此规则。
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [ // 确保Google移动服务的特定域名走代理，保证FCM推送等工作。
          {
            "domain_suffix": [
              "mtalk.google.com", "alt1-mtalk.google.com", "alt2-mtalk.google.com",
              "alt3-mtalk.google.com", "alt4-mtalk.google.com", "alt5-mtalk.google.com",
              "alt6-mtalk.google.com", "alt7-mtalk.google.com", "alt8-mtalk.google.com"
            ]
          },
          { "port": [443, 5228] }
        ],
        "outbound": "PROXY"
      },
      // 去广告规则 (所有版本共有)
      {
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "action": "reject"
      },
      // NTP流量强制直连
      {
        "domain_keyword": ["ntp", "time"],
        "network": "udp",
        "port": 123,
        "outbound": "DIRECT" // 精简版outbound为"🎯 direct"
      },
      // 拦截 STUN, TURN, httpdns 等协议，防止WebRTC泄露IP或DNS泄露。
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "network": "udp", "port": [3478, 5349, 5350, 19302, 10000] },
          { "domain_regex": "^stun\\..+" },
          { "domain_keyword": ["stun", "turn", "httpdns"] },
          { "protocol": "stun" }
        ],
        "action": "reject"
      },
      // 拦截欺诈/钓鱼网站 (所有版本共有)
      {
        "rule_set": "anti_fraud",
        "action": "reject"
      },
      // 局域网流量直连 (所有版本共有)
      {
        "ip_is_private": true,
        "outbound": "DIRECT"
      },
      // FakeIP地址段必须走代理，否则无法正常连接 (所有版本共有)
      {
        "ip_cidr": ["198.18.0.0/15"],
        "outbound": "PROXY"
      },
      // 基于Wi-Fi网络的规则 (优化版/稳定版/强化版)
      {
        "wifi_ssid": ["MyHomeWiFi"], // 连接特定Wi-Fi时强制使用代理。
        "outbound": "PROXY"
      },
      {
        "wifi_bssid": ["00:11:22:33:44:55"], // 连接特定路由器时强制直连。
        "outbound": "DIRECT"
      },
      // 规则集分流 (所有版本共有)
      {
        "rule_set": ["telegramip","geosite-google", "proxy","games","ai"], // 精简版无此复合规则，分散到各selector中。
        "outbound": "PROXY"
      },
      {
        "rule_set": ["private", "cn", "cnip", "microsoft-cn", "apple-cn", "google-cn", "games-cn", "networktest"],
        "outbound": "DIRECT"
      },
      { "action": "resolve" }, // 对剩余流量进行DNS解析，以便后续可能基于IP的规则匹配。
      // 稳定版特有: 为特定IP和域名添加直连规则作为示例。
      {
        "ip_cidr": ["1.1.1.1/32"],
        "outbound": "DIRECT"
      },
      {
        "domain": ["www.google.com", "www.apple.com"],
        "outbound": "DIRECT"
      },
      // === 强化版特有规则 ===
      {
        "action": "route-options",
        "udp_disable_domain_unmapping": true, // 禁用UDP域名的反解，提升性能。
        "udp_connect": true // 使用UCP Connect，类似TCP的连接行为，更稳定。
      },
      {
        "rule_set": ["Ads", "adobe", "httpDNS", "DNSreject"],
        "action": "reject",
        "method": "drop" // 直接丢弃，不回复，节省资源。
      },
      { "clash_mode": "Global", "outbound": "PROXY" }, // 兼容Clash全局模式
      { "clash_mode": "Direct", "outbound": "DIRECT" }, // 兼容Clash直连模式
      {
        "rule_set": ["fcm", "Android"],
        "outbound": "PROXY" // 确保Android系统和FCM推送走代理。
      },
      {
        "domain_suffix": ["google.cn", "googleapis.cn"],
        "outbound": "PROXY" // 即使是CN域名，Google服务仍可能需要代理。
      },
      {
        "rule_set": ["telegram", "telegram_ip", "youtube", "instagram", "Google", "ai", "GlobalMedia", "Proxy", "gfw"],
        "outbound": "PROXY" // 强化的代理规则集。
      },
      {
        "rule_set": ["private", "Applications", "OnePlus"],
        "outbound": "DIRECT" // 增强的直连规则集。
      },
      {
        "protocol": ["ntp", "icmp"], // NTP和ICMP协议直连。
        "outbound": "DIRECT"
      },
      {
        "protocol": ["stun", "quic", "dtls"], // 再次拒绝STUN等协议。
        "action": "reject"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [ // 拦截非中国IPv6地址的流量，防止在无IPv6环境下发生连接问题。
          { "ip_version": 6 },
          { "default_interface_address": "2000::/3", "invert": true } // 2000::/3是全球单播IPv6地址段，反选即匹配非全球单播地址。
        ],
        "action": "reject"
      },
      // === 精简版特有规则 ===
      { "clash_mode": "Direct", "outbound": "🎯 direct" },
      { "clash_mode": "Global", "outbound": "✈️ Proxy" },
      { "rule_set": "geosite-category-ads-all", "action": "reject" },
      { "rule_set": ["geosite-cn", "geoip-cn"], "outbound": "🎯 direct" },
      {
        "type": "logical",
        "mode": "or",
        // 精细化控制AI服务走专用选择器。
        "rules": [
          { "rule_set": ["geosite-openai", "geosite-anthropic", "geosite-google-gemini"] },
          { "domain_suffix": ["chatgpt.com", "claude.ai", "gateway.ai.cloudflare.com", "grok.com", "groq.com", "meta.ai", "openart.ai", "openrouter.ai", "perplexity.ai", "x.ai"] }
        ],
        "outbound": "🤖 AI"
      },
      { "rule_set": ["geosite-youtube", "geosite-netflix"], "outbound": "▶️ YouTube" },
      { "rule_set": "geosite-telegram", "outbound": "📱 Telegram" },
      { "rule_set": "geosite-geolocation-!cn", "outbound": "♻️ 自动选择" } // 最终，所有非中国域名走自动选择。
