{
  // ==================================================
  // 全局注释与说明
  // ==================================================
  // 本 JSON 配置基于 sing-box 1.14.0-alpha.18 内核，合并了优化版、稳定版、强化版、精简版四个版本。
  // 所有版本的共同配置将只出现一次，并在关键位置用注释标出不同版本的差异。
  //
  // 核心版本差异概览：
  // - 优化版: 注重国内网站(尤其是AI网站)直连速度，使用阿里DNS系列服务器，DNS和路由规则细致。
  // - 稳定版: 在优化版基础上微调，去掉了一些实验性配置(如ECH)，节点使用自动测速，策略偏向保守。
  // - 强化版: 在稳定版基础上大幅增加规则集，增强去广告、隐私保护和代理分流，内存和性能优化更激进。
  // - 精简版: 配置极简，追求低内存占用和快速启动，只保留最核心的分流和代理功能，适合低配设备。
  //
  // 疑惑解答:
  // 1. "dns"部分的"predefined"字段: 用于预定义主机名(hosts)，将特定域名解析为指定的IP，常用于绕过DNS污染或加速特定服务。
  // 2. "detour"字段: 指连接此服务器应使用的出站(outbound)标签。设置为"DIRECT"即直连，"PROXY"即通过代理。
  // 3. "clash_mode"字段: 这是sing-box为兼容Clash模式而设计的，允许通过UI快速切换"规则"、"全局"、"直连"模式。
  // 4. "rule_set"的"format"字段: "binary"(.srs)格式比"source"(json)加载更快，内存占用更少。精简版为节省空间未指定，默认下载source格式。
  // 5. "experimental"部分: "cache_file"会缓存DNS、规则集等数据，显著加快重启后的启动速度。"clash_api"提供与Clash兼容的API，用于连接Metacubexd等Web面板。
  // 6. "domain_resolver"字段: 指定用于解析该服务器自身域名的DNS服务器标签，常用于解决循环解析问题。例如，"hosts_fix"预定义了国内DNS服务器的IP，使系统在无DNS时也能解析它们。

  // ==================================================
  // 日志配置 (所有版本相同，精简版级别为"warn")
  // ==================================================
  "log": {
    "level": "trace", // 日志级别: trace(最详细), debug, info, warn, error, fatal。精简版为"warn"。
    "timestamp": true // 为每条日志添加时间戳
  },

  // ==================================================
  // NTP 时间同步 (优化版/稳定版/强化版相同，精简版使用 time.apple.com)
  // ==================================================
  "ntp": {
    "enabled": true,
    "server": "ntp.aliyun.com", // 精简版使用 "time.apple.com"
    "server_port": 123,
    "interval": "30m", // 同步间隔。稳定版/强化版为 "30m0s"，功能一致。
    "detour": "DIRECT" // 强制NTP流量直连，避免因代理导致时间不准。
  },

  // ==================================================
  // DNS 服务器及规则
  // ==================================================
  "dns": {
    "servers": [
      // 基础DNS服务器 (所有版本均有)
      {
        "tag": "local",
        "type": "local" // 使用系统本地DNS，通常为路由器分配的DNS。
      },
      {
        "tag": "hosts_fix",
        "type": "hosts",
        "predefined": { // 预定义HOSTS，静态解析，防止DNS污染或劫持。
          "dns.huaweicloud.com": ["180.163.150.33", "180.163.151.33"],
          "dns.alidns.com": ["223.5.5.5", "223.6.6.6"],
          "doh.pub": ["1.12.12.21", "120.53.53.53"],
          "dns.google": ["8.8.8.8", "8.8.4.4"],
          "cloudflare-dns.com": ["104.16.248.249", "104.16.249.249"],
          "mtalk.google.com": ["142.250.107.188", "142.251.170.188", "108.177.125.188"],
          "alt1-mtalk.google.com": ["2607:f8b0:4023:1c05::bc", "74.125.200.188"],
          "dl.google.com": ["180.163.151.161"],
          "dl.l.google.com": ["180.163.150.33"]
          // 强化版增加了 "dns.adguard.com": [...] 的解析。
        }
      },
      // 国内高速DNS (阿里DNS over TLS) (优化版/稳定版/强化版共有，精简版无)
      {
        "tag": "alidns-dot",
        "type": "tls",
        "server": "dns.alidns.com",
        "server_port": 853,
        "domain_resolver": "hosts_fix", // 使用预定义hosts来解析"dns.alidns.com"的IP。
        "detour": "DIRECT" // 通过直连出站连接。
      },
      // 国内高速DNS (阿里DNS over QUIC) (优化版/稳定版/强化版共有，精简版使用标准QUIC直连223.5.5.5)
      {
        "tag": "alidns-quic",
        "type": "quic",
        "server": "dns.alidns.com",
        "domain_resolver": "hosts_fix",
        "detour": "DIRECT"
      },
      // 海外代理DNS (Google DNS over HTTPS) (优化版/稳定版/强化版共有，精简版类似但tag为"google", type为"tls")
      {
        "tag": "ggdns",
        "type": "https",
        "server": "dns.google",
        "domain_resolver": "hosts_fix",
        "detour": "PROXY" // 强制通过代理连接，确保拿到无污染的海外DNS结果。
      },
      // 实验性ECH DNS (仅优化版)
      // ECH (Encrypted Client Hello) 是一种TLS隐私增强技术。
      {
        "tag": "doh-ech",
        "type": "https",
        "server": "dns.google",
        "path": "/dns-query",
        "detour": "PROXY"
      },
      // FakeDNS/FakeIP (所有版本共有)
      // 对匹配的域名立即返回一个虚拟IP，延迟连接，待真实请求发出后再解析真实IP。可优化国内有CDN的网站访问速度。
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15" // 强化版还配置了 "inet6_range": "fc00::/18"
      },
      // 广告过滤DNS (仅强化版)
      {
        "tag": "adguard-dns",
        "type": "tls",
        "detour": "PROXY",
        "domain_resolver": "hosts_fix",
        "server": "dns.adguard.com", // 使用AdGuard的公共DNS，可过滤广告和跟踪器。
        "server_port": 853
      }
    ],

    "rules": [
      // === 所有版本共有规则 ===
      {
        // 广告和跟踪器域名，直接拒绝解析 (稳定版和强化版也将此规则放在靠后位置)
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "action": "reject"
      },
      {
        // 拒绝不必要的DNS查询类型，减少特征和泄露。
        "query_type": ["SVCB", "HTTPS", "PTR"],
        "action": "reject"
      },

      // === 优化版/稳定版/强化版共有规则 ===
      {
        // 本地局域网及智能设备管理域名，使用本地DNS解析。
        "domain_suffix": [
          ".local", ".lan",
          "miwifi.com", "tplogin.cn", "router.asus.com", "tendawifi.com", "tplinkwifi.net"
        ],
        "server": "local" // 或 "alidns-quic"，优化版在第一个大规则组中包含它们并指向"alidns-quic"。
      },
      // 优化版特有的详细规则: 将大量国内AI和内容平台域名明确指向阿里DNS，保证速度和稳定性。
      // 如: "api.deepseek.com", "www.bilibili.com"等。
      {
        "domain_suffix": [
          // ... 优化版/稳定版/强化版共享的大量国内域名，如:
          "hm.baidu.com", "tracking.miui.com",
          "douyinvod.com", "douyincdn.com", "ixigua.com", "pstatp.com", "bytecdn.com", "volccdn.com",
          "speedtest.net", "fast.com",
          "zhihu.com", "zhimg.com", "jd.com", "360buyimg.com",
          "xfyun.cn", "dashscope.aliyuncs.com", "api.moonshot.cn", "api.baichuan-ai.com",
          "api.minimax.chat", "api.sensenova.cn", "api.iflytek.com", "xinghuo.xfyun.cn",
          "chatglm.cn", "bigmodel.cn", "volces.com", "lingyiwanwu.com", "stepfun.com", "zhipuai.cn",
          "chat.deepseek.com", "www.deepseek.com", "api.bilibili.com", "www.bilibili.com",
          "market.xiaomi.com"
        ],
        "server": "alidns-quic"
      },
      // 优化版将 ".cn" 和 ".com.cn" 域名先使用evaluate规则交给alidns-dot评估
      {
        "domain_suffix": [".cn", ".com.cn"],
        "action": "evaluate", // evaluate会同时查询路由表和DNS规则，不立即决定。
        "server": "alidns-dot"
      },
      {
        "domain_suffix": [".cn", ".com.cn"],
        "server": "alidns-quic" // 如果evaluate未匹配，则由alidns-quic处理。稳定版/强化版无evaluate，直接使用此规则。
      },
      // Steam缓存域名，使用本地DNS。
      {
        "domain_suffix": "lancache.steamcontent.com",
        "server": "local"
      },
      // 游戏平台和Google服务，使用FakeIP。
      {
        "domain_suffix": [
          "steamcontent.com", "steamserver.net",
          "epicgames.com", "gog.com", "battle.net", "blizzard.com", "origin.com", "ea.com", "ubisoft.com", "rockstargames.com",
          "play.google.com", "ggpht.com", "googleusercontent.com", "android.com",
          "app-measurement.com",
          "firebaselogging.googleapis.com", "firebaselogging-pa.googleapis.com",
          "beacons.gvt2.com", "beacons2.gvt2.com", "beacons3.gvt2.com"
        ],
        "server": "fakeip"
      },
      // 代理、游戏、AI类域名使用FakeIP并进行客户端子网重写 (优化版独有)
      {
        "rule_set": ["proxy", "games", "ai"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip",
        "rewrite_ttl": 300,
        "client_subnet": "119.134.100.0/24" // 向DNS服务器报告一个假的客户端子网，可能获取更优的CDN节点。
      },
      // 稳定版的对应规则，没有client_subnet。
      {
        "query_type": ["A", "AAAA"],
        "rule_set": ["proxy", "games", "ai"],
        "server": "fakeip",
        "rewrite_ttl": 300
      },
      // 强化版: 关联proxy/games/ai的A/AAAA查询先通过adguard-dns过滤，再走fakeip。
      {
        "query_type": ["A", "AAAA"],
        "rule_set": ["proxy", "games", "ai"],
        "server": "adguard-dns"
      },
      {
        "query_type": ["A", "AAAA"],
        "rule_set": ["proxy", "games", "ai"],
        "server": "fakeip",
        "rewrite_ttl": 300
      },
      // 优化版: 对应节点域名的查询使用ECH DNS。
      {
        "domain_suffix": ["节点域名"], // 这是占位符，使用者需替换为自己的节点域名。
        "server": "doh-ech"
      },
      // 匹配所有国内IP的响应，路由到本地DNS，确保准确性。
      {
        "match_response": true,
        "rule_set": "cnip",
        "action": "route",
        "server": "local"
      },
      // 匹配DNS响应结果，如果以上规则均未匹配，则直接响应。
      {
        "match_response": true,
        "action": "respond"
      },
      // 强化版: 主动拒绝部分不必要查询，或直接返回NOERROR。
      {
        "query_type": ["A", "AAAA"],
        "invert": true, // 反转匹配，即非A/AAAA查询
        "action": "predefined",
        "rcode": "NOERROR" // 返回成功但无结果，防止客户端一直等待。
      },
      {
        "rule_set": ["httpDNS", "DNSreject", "Ads"],
        "action": "predefined",
        "rcode": "NOERROR"
      },
      {
        "rule_set": ["private", "Filter"],
        "server": "alidns-quic" // 特定规则集使用国内DNS。
      },
      // 精简版: 基于Clash模式的DNS分流。
      {
        "clash_mode": "Direct",
        "server": "local"
      },
      {
        "clash_mode": "Global",
        "server": "google"
      },
      {
        "query_type": ["AAAA"], // 精简版: 所有IPv6查询走本地，避免代理。
        "server": "local"
      },
      {
        "rule_set": "geosite-cn", // 精简版: 中国域名使用本地DNS。
        "server": "local"
      },
      {
        "query_type": ["A"], // 精简版: 作为最终规则，所有A记录查询走fakeip。
        "server": "fakeip"
      }
    ],
    // 最终兜底DNS服务器
    "final": "doh-ech", // 优化版使用ECH DNS。稳定版/强化版使用 "ggdns"。精简版无final。
    // 其他DNS配置
    "strategy": "prefer_ipv4", // 优先使用IPv4。所有版本相同。
    "reverse_mapping": true, // 尝试从FakeIP反向映射回域名，对某些应用有用。精简版无此配置。
    "cache_capacity": 65536, // DNS缓存大小。精简版无。
    "optimistic": true // 乐观DNS，同时向所有匹配服务器查询，取第一个响应。精简版无。
  },

  // ==================================================
  // HTTP 客户端配置
  // ==================================================
  "http_clients": [
    {
      "tag": "default",
      // 优化版/稳定版/强化版:
      "detour": "PROXY", // 通过PROXY出站下载规则集等资源。
      // 精简版:
      // "detour": "♻️ 自动选择"
      "version": 2, // 稳定版/强化版/精简版指定使用HTTP/2。
      "stream_receive_window": 0, // 稳定版/强化版特有，流控窗口，0为使用内核默认值。
      "connection_receive_window": 0 // 稳定版/强化版特有。
    }
  ],

  // ==================================================
  // 入站（Inbounds）配置
  // ==================================================
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      // 优化版/稳定版/强化版:
      "address": ["10.8.0.1/24"],
      // 精简版:
      // "address": "172.19.0.1/30",
      "mtu": 1500, // 最大传输单元。精简版无，使用系统默认。
      "stack": "mixed", // 网络栈: mixed(混合), system(系统), gvisor。精简版使用 "system"。
      "auto_route": true, // 自动设置路由，接管所有流量。
      "strict_route": true, // 严格路由，防止路由泄露。
      // 精简版特有: 为TUN模式配置自动HTTP代理，方便不支持TUN的应用使用。
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 7890
        }
      }
    },
    {
      "type": "mixed", // 混合入站，支持HTTP和SOCKS5。
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],

  // ==================================================
  // 出站（Outbounds）配置
  // ==================================================
  "outbounds": [
    // 直连出站 (所有版本共有)
    {
      "type": "direct",
      "tag": "DIRECT", // 精简版tag为 "🎯 direct"
      "domain_resolver": "alidns-quic" // 精简版无此配置。优化版/稳定版/强化版指定此出站的域名由阿里DNS解析。
    },
    // 代理选择器 (PROXY) (优化版/稳定版/强化版共有，精简版无此层级)
    {
      "type": "selector",
      "tag": "PROXY", // 精简版对应为 "✈️ Proxy"
      "outbounds": [
        "AUTO", // 自动测速组。精简版对应 "♻️ 自动选择"
        // 优化版:
        "🚀 CF-优选-Visa",
        "🚀 CF-优选-DO",
        // 稳定版/强化版:
        "🇺🇸 pkpk01",
        "🇺🇸 pkpk02",
        // 精简版:
        // "♻️ 自动选择",
        "DIRECT" // 精简版对应 "🎯 direct"
      ],
      "default": "AUTO", // 默认使用自动测速组。精简版选择器的默认由各selector自行定义。
      "interrupt_exist_connections": false // 切换节点时不中断已有连接。优化版特有，稳定版/强化版无。
    },
    // 自动测速组 (所有版本共有)
    {
      "type": "urltest",
      "tag": "AUTO", // 精简版对应 "♻️ 自动选择"
      "outbounds": [
        "🚀 CF-优选-Visa", "🚀 CF-优选-DO", // 优化版
        "🇺🇸 pkpk01", "🇺🇸 pkpk02" // 稳定版/强化版/精简版
      ],
      "url": "http://cp.cloudflare.com/", // 优化版测速URL。
      // 稳定版/强化版/精简版: "url": "http://www.gstatic.com/generate_204"
      "interval": "10m", // 测速间隔。精简版为 "5m"。
      "tolerance": 50, // 容忍度(ms)，低于此差异不会触发切换。
      "idle_timeout": "30m", // 节点空闲超时，将重新测速。精简版无此配置。
      "interrupt_exist_connections": false // 优化版特有。
    },
    // 以下为优化版/稳定版/强化版共有的更多选择器组，精简版在其他地方定义
    {
      "type": "selector",
      "tag": "GLOBAL",
      "outbounds": ["PROXY", "DIRECT"],
      "default": "PROXY"
    },
    {
      "type": "selector",
      "tag": "CN",
      "outbounds": ["DIRECT", "PROXY"],
      "default": "DIRECT"
    },
    {
      "type": "selector",
      "tag": "Final", // 路由最终兜底出站
      "outbounds": ["PROXY", "DIRECT", "REJECT-DROP"],
      "default": "REJECT-DROP" // 优化版默认拒绝，更安全。稳定版/强化版为 "PROXY"。
    },
    {
      "type": "block",
      "tag": "REJECT-DROP" // 用于主动拒绝或丢弃连接。
    },
    // 精简版特有的选择器组
    {
      "type": "selector",
      "tag": "🤖 AI",
      "outbounds": ["♻️ 自动选择", "✈️ Proxy"]
    },
    {
      "type": "selector",
      "tag": "▶️ YouTube",
      "outbounds": ["♻️ 自动选择", "✈️ Proxy"]
    },
    {
      "type": "selector",
      "tag": "📱 Telegram",
      "outbounds": ["♻️ 自动选择", "✈️ Proxy"]
    },
    {
      "type": "selector",
      "tag": "✈️ Proxy",
      "outbounds": ["♻️ 自动选择", "🎯 direct"]
    },
    // 块出站 (精简版)
    {
      "type": "block",
      "tag": "block"
    },

    // ==================================================
    // 节点配置 (所有版本共有，但具体参数有差异)
    // ==================================================
    {
      "type": "vless",
      // 优化版:
      "tag": "🚀 CF-优选-Visa",
      // 稳定版/强化版/精简版:
      // "tag": "🇺🇸 pkpk01",
      "server": "CF优选域名IP", // 占位符，需替换
      "server_port": 443,
      "uuid": "uuid", // 占位符，需替换
      // 优化版/稳定版/强化版:
      "domain_resolver": "alidns-quic", // 解析服务器地址的DNS。精简版无。
      // 连接优化 (强化版特有，精简版无)
      "tcp_fast_open": true,
      "tcp_keep_alive": "30s",
      "tcp_keep_alive_interval": "5s",
      "udp_fragment": true,
      "packet_encoding": "xudp", // 强化版特有，xudp可以更稳定地代理UDP流量。
      "transport": {
        "type": "ws",
        "path": "/路径", // 占位符，需替换。稳定版/强化版/精简版为 "/pkpk-vl"
        "headers": { "Host": "节点域名" }, // 占位符，需替换
        "max_early_data": 2560, // 开启0-RTT，减少连接耗时。稳定版/强化版/精简版特有。
        "early_data_header_name": "Sec-WebSocket-Protocol" // 稳定版/强化版/精简版特有。
      },
      "tls": {
        "enabled": true,
