// ╔══════════════════════════════════════════════════════════════════════╗
// ║   sing-box 1.14.0-alpha.26 · Android · FakeIP+TUN 全配置逐行注释      ║
// ║   每一行都有解释 / 说明 / 疑惑解答 / 总结                               ║
// ╚══════════════════════════════════════════════════════════════════════╝

// ──────────────────────────────────────────
// 日志配置
// ──────────────────────────────────────────
// level="fatal": 只记录致命错误，日常不刷屏。调试时改成debug看完整链路
// timestamp=true: 每条日志带时间戳，方便排查问题时间线
// 为什么不用debug：手机性能有限，debug日志量巨大(每秒几十条)，日常用fatal足够
{
  "log": {
    "level": "fatal",      // fatal=只记录崩溃级错误 / debug=看完整DNS+路由链路 / warn=记录警告
    "timestamp": true       // 日志带时间戳，定位问题用。比如看DNS解析花了多少ms
  },

  // ═══════════════════════════════════════════════
  // DNS 配置 —— 整个架构的核心，国内和国外在这里分流
  // ═══════════════════════════════════════════════
  "dns": {
    "servers": [
      // ── DNS服务器1：hosts本地硬编码 ──
      // 作用：预先写死DNS服务器本身的IP，避免"解析DNS服务器需要DNS服务器"的死循环
      // 为什么需要：alidns-quic要连dns.alidns.com，但dns.alidns.com本身需要DNS解析
      //             hosts直接告诉sing-box dns.alidns.com的IP，不需要再查
      {
        "type": "hosts",           // hosts类型：本地域名→IP映射表，不走网络查询
        "tag": "hosts_fix",        // 标签名，供其他DNS服务器的domain_resolver引用
        "predefined": {            // 预定义的静态映射
          "dns.alidns.com": [      // 阿里公共DNS的域名
            "223.5.5.5",           // 阿里DNS IPv4地址1
            "223.6.6.6"            // 阿里DNS IPv4地址2（备用）
          ],
          "dns.google": [          // Google公共DNS的域名
            "8.8.8.8",             // Google DNS IPv4地址1
            "8.8.4.4"              // Google DNS IPv4地址2（备用）
          ]
          // 疑惑：为什么不加IPv6地址？
          // 答：这台手机网络不支持IPv6，加了也没用，反而可能超时。如果以后网络支持v6再加
        }
      },

      // ── DNS服务器2：阿里DNS-over-QUIC（国内主力） ──
      // 说明：阿里公共DNS，使用QUIC协议(UDP 443端口)加密传输
      // 为什么用QUIC而不是普通UDP53：国内运营商会劫持UDP53的DNS查询返回错误IP
      //   QUIC走443端口而且是加密的，运营商劫持不了
      // 为什么用阿里DNS而不是DNSPod/114：阿里QUIC国内响应最快（5-20ms）
      {
        "type": "quic",                    // QUIC协议DNS（DoQ = DNS over QUIC）
        "tag": "alidns-quic",              // 标签名，供DNS规则和路由引用
        "detour": "direct",                // 连接DNS服务器用direct出站（直连，不走代理）
        "domain_resolver": "hosts_fix",    // 解析dns.alidns.com时用hosts_fix的硬编码IP
        "server": "dns.alidns.com"         // 上游DNS服务器域名
      },

      // ── DNS服务器3：Google DNS-over-HTTPS（备用，极少触发） ──
      // 说明：走代理连Google DNS，用于极端情况下解析被污染的域名
      // 当前状态：被fakeip规则兜底拦截，极少实际使用
      {
        "type": "https",                   // HTTPS协议DNS（DoH = DNS over HTTPS）
        "tag": "proxy-dns",                // 标签名
        "detour": "smart-proxy",           // 通过代理连接Google DNS
        "domain_resolver": "hosts_fix",    // 用hosts硬编码IP解析dns.google本身
        "server": "dns.google"             // 上游DNS服务器域名
      },

      // ── DNS服务器4：FakeIP（国外流量核心） ──
      // 说明：不给真实IP，返回198.18.x.x的假IP
      // 为什么用FakeIP：
      //   1. 防DNS泄露：国外域名完全不走任何上游DNS
      //   2. 路由精准：拿假IP的流量必然走代理，不会误判
      //   3. 性能：本地直接生成IP，不需要网络查询
      // 198.18.0.0/15是什么：IANA保留的基准测试网段，公网上没有这个IP
      //   fc00::/18是什么：IPv6的Unique Local Address，相当于v6版的私有地址
      {
        "type": "fakeip",                  // FakeIP类型DNS服务器
        "tag": "fakeip",                   // 标签名
        "inet4_range": "198.18.0.0/15",    // IPv4假IP范围（198.18.0.0 - 198.18.1.255）
        "inet6_range": "fc00::/18"         // IPv6假IP范围
      }
    ],

    // ── DNS 规则：域名→DNS服务器的映射 ──
    // 顺序非常重要！从上到下匹配，命中即停
    // 前四条是"国内通道"，拦截所有国内域名走阿里DNS
    // 后四条是"处理通道"，拒绝/给假IP
    "rules": [

      // 规则①：Filter规则集 → 阿里DNS
      // 说明：fakeip-filter.srs，收录了需要绕过fakeip的域名
      // 为什么需要绕过：有些域名(尤其是CDN)拿假IP会导致CDN调度错误
      // 来源：DustinWin维护，每48小时自动更新
      // 举例：cdn.jsdelivr.net(规则集下载域名)、CDN厂商域名等
      {
        "rule_set": "Filter",              // 匹配Filter规则集中的域名
        "server": "alidns-quic"            // 用阿里DNS解析，拿真实IP
      },

      // 规则②：中国顶级域名 → 阿里DNS
      // 说明：所有.cn域名和中文TLD硬匹配，100%物理兜底
      // 为什么放在Filter之后：Filter里可能有非.cn的CDN域名需要优先处理
      // .xn--fiqs8s = .中国 的punycode编码
      // .xn--55qx5d = .公司 的punycode编码
      // .xn--io0a7i = .网络 的punycode编码
      // 疑惑：会不会把gov.cn等也拦截了？
      // 答：domain_suffix ".cn" 匹配所有以.cn结尾的域名，包括gov.cn，全部走阿里DNS直连正常
      {
        "domain_suffix": [                 // 域名后缀匹配
          ".cn",                           // 所有.cn域名(包括com.cn, net.cn, gov.cn等)
          ".xn--fiqs8s",                   // .中国 (IDN punycode)
          ".xn--55qx5d",                   // .公司
          ".xn--io0a7i"                    // .网络
        ],
        "server": "alidns-quic"            // 用阿里DNS解析
      },

      // 规则③：国内CDN域名白名单 → 阿里DNS
      // 说明：这些域名都是.com结尾的国际TLD，geosite:cn不一定全收录
      //      但它们的CDN节点实际部署在中国，走代理会严重降速
      // 这是从旧版配置最关键的补丁——抖音/B站/快手/淘宝的CDN域名
      {
        "domain_suffix": [
          // ── 抖音/字节跳动系 ──
          "douyinvod.com",     // 抖音视频CDN(vod=video on demand)
          "ibytedtos.com",     // 字节国际CDN(bytedtos=ByteDance TOS)
          "pstatp.com",        // 字节图片/统计CDN
          "byteimg.com",       // 字节图片CDN(img=image)
          "bytecdn.com",       // 字节通用CDN
          "snssdk.com",        // 字节跳动核心域名(SNS SDK)
          "bytedance.com",     // 字节跳动主域名
          "toutiao.com",       // 今日头条
          "ixigua.com",        // 西瓜视频
          "volcengine.com",    // 火山引擎(字节云服务)

          // ── 快手系 ──
          "kuaishou.com",      // 快手主域名
          "yximgs.com",        // 快手图片CDN

          // ── B站系 ──
          "bilivideo.com",     // B站视频CDN
          "hdslb.com",         // B站核心域名

          // ── 阿里系 ──
          "alicdn.com",        // 淘宝/天猫/1688图片和静态资源CDN
          "aliyuncs.com",      // 阿里云OSS对象存储

          // ── 腾讯系 ──
          "gtimg.com",         // QQ/微信图片CDN

          // ── 京东系 ──
          "360buyimg.com",     // 京东商品图片CDN

          // ── 拼多多 ──
          "pinduoduo.com"      // 拼多多主域名
          // 疑惑：如果以后发现新的国内CDN域名怎么办？
          // 答：加到这两个list里(本DNS规则 + 下面路由规则⑫)，格式一致
        ],
        "server": "alidns-quic"            // 用阿里DNS解析，拿真实IP
      },

      // 规则④：cn规则集 → 阿里DNS
      // 说明：geosite:cn收录的所有中国域名，最后一道规则集兜底
      // 来源：DustinWin cn.srs，每48小时自动更新
      // 覆盖度：数千个中国域名，包括不常见的政府/教育/企业站点
      {
        "rule_set": "cn",                  // 匹配cn规则集中的域名
        "server": "alidns-quic"            // 用阿里DNS解析
      },

      // 规则⑤：SVCB/HTTPS/PTR → 拒绝
      // 说明：这三种DNS记录类型全部拒绝
      // SVCB/HTTPS：HTTP/3连接信息，可能包含真实IP提示(ipv4hint/ipv6hint)
      //              如果让客户端拿到真实IP，会绕过fakeip的IP伪装
      // PTR：反向DNS查询(IP→域名)，普通应用不需要
      // 拒绝后：客户端收到拒绝响应 → 自动重试A(IPv4)/AAAA(IPv6)查询
      // 为什么放第五而不是第一：
      //   规则集下载域名cdn.jsdelivr.net在规则①的Filter里，SVCB被拒后快速A查询
      //   国内域名在前四条已拦截完，SVCB被拒对国内无影响
      {
        "query_type": [                    // 按DNS查询类型匹配
          "SVCB",                          // Service Binding，HTTP/3连接信息
          "HTTPS",                         // HTTPS DNS记录，同SVCB类似
          "PTR"                            // 反向DNS查询，IP→域名
        ],
        "action": "reject"                 // 拒绝该查询
      },

      // 规则⑥：广告拦截 → 拒绝
      // 三套广告规则集叠加，最大覆盖
      {
        "rule_set": [
          "geosite_adguard",               // AdGuard规则(sing-box格式)
          "geosite-category-ads-all",      // geosite广告分类(全量)
          "DNSreject"                       // AdGuard SDNS过滤规则
        ],
        "action": "reject"                 // 拒绝广告域名的DNS查询
      },

      // 规则⑦：.local域名 → 拒绝
      // 说明：局域网域名如 printer.local、nas.local
      // 为什么拒绝：这些域名在公网上不存在，去上游查也是白查，直接拒更快
      {
        "domain_suffix": ".local",         // 所有以.local结尾的域名
        "action": "reject"                 // 拒绝
      },

      // 规则⑧：全部 → fakeip
      // 说明：以上七条都没命中 = 一定是国外域名
      // 给一个198.18.x.x的假IP，后续路由层靠这个假IP识别为代理流量
      // 关键安全特性：国外域名从始至终没有经过任何上游DNS！
      // 域名→假IP的映射完全在手机本地完成
      // 运营商/GFW看到的是：你连了一个198.18.x.x的IP（无意义保留地址）→ 然后又连了代理节点的加密流量
      {
        "server": "fakeip"                 // 所有剩余域名走fakeip
      }
    ],

    // ── DNS全局设置 ──
    "final": "proxy-dns",                  // 最终的兜底DNS（当前被规则⑧拦截，极少触发）
    "reverse_mapping": false,              // 关闭反向DNS映射
    // 为什么关reverse_mapping：
    //   true时每个连接sing-box都会做一次PTR查询来找域名
    //   对国内直连来说，每次连接凭空多一次DNS查询
    //   false只是不自动做PTR，不影响正常功能

    "strategy": "prefer_ipv4",             // DNS策略：优先IPv4
    // 为什么prefer_ipv4而不是default：
    //   这台手机网络不支持IPv6
    //   default会用系统偏好(可能是v6优先)→ 连接v6超时 → 等3-5秒回退v4 → 卡
    //   prefer_ipv4直接用v4地址，省去无效的v6尝试

    "timeout": "2s",                       // DNS查询超时2秒
    // 为什么2秒：旧版3秒，但阿里QUIC正常5-20ms就回来了
    //   2秒足够了，超时说明网络有问题，快速失败快速尝试备用

    "cache_capacity": 16384,               // DNS缓存容量：16384条
    // 为什么16384：旧版256000太大了，每个条目占内存
    //   16384足够覆盖日常使用的所有域名，且省内存
    //   移动端4-6GB内存，这条差不多占用10-20MB

    "optimistic": {                        // 乐观DNS缓存
      "enabled": true,                     // 开启
      "timeout": "1h0m0s"                  // 缓存1小时后过期
    }
    // 乐观缓存原理：
    //   1. DNS记录有效期(比如TTL=300秒)到了 → 先返回旧结果(0ms给客户端)
    //   2. 同时后台去阿里DNS查新的 → 静默更新缓存
    //   3. 用户无感知，永远0ms命中
    // 为什么1小时：抖音视频CDN域名变化不频繁，1小时够用
    //   1小时后即使缓存过期，也会再走一次乐观刷新
  },

  // ═══════════════════════════════════════════════
  // NTP 授时配置
  // ═══════════════════════════════════════════════
  "ntp": {
    "enabled": true,                       // 开启NTP时间同步
    "interval": "30m0s",                   // 每30分钟同步一次
    "server": "ntp.aliyun.com",            // 阿里云NTP服务器（国内）
    "server_port": 123,                    // NTP标准端口
    "detour": "direct"                     // 走直连，不过代理
    // 为什么用direct而不是smart-proxy：
    //   旧版这里写的是smart-proxy → ntp.aliyun.com是国内服务器
    //   走代理意味着：手机 → 代理节点(出国) → 再连回阿里云授时 → 绕地球一圈
    //   改成direct直接连阿里云，秒同步
  },

  // ═══════════════════════════════════════════════
  // HTTP客户端（用于下载规则集）
  // ═══════════════════════════════════════════════
  "http_clients": [
    // ── 默认HTTP客户端：直连下载规则集 ──
    {
      "tag": "default",                    // 标签名
      "version": 2,                        // HTTP/2
      "detour": "direct",                  // 走直连
      "stream_receive_window": 0,          // 0=使用系统默认
      "connection_receive_window": 0       // 0=使用系统默认
      // 为什么规则集下载走直连：
      //   规则集托管在cdn.jsdelivr.net，有国内CDN节点
      //   直连比走代理快得多
    },

    // ── 代理HTTP客户端（备用） ──
    {
      "tag": "proxy",                      // 标签名
      "version": 2,                        // HTTP/2
      "detour": "smart-proxy",             // 走代理
      "domain_resolver": "alidns-quic",    // 用阿里DNS解析
      "stream_receive_window": 0,
      "connection_receive_window": 0
    }
  ],

  // ═══════════════════════════════════════════════
  // 入站（inbounds）—— 流量入口
  // ═══════════════════════════════════════════════
  "inbounds": [
    // ── TUN入站：系统级接管所有流量 ──
    // 说明：在Android上创建一个虚拟网卡，所有APP的流量都先经过这个虚拟网卡
    // 然后sing-box根据路由规则决定每个连接走direct还是proxy
    {
      "type": "tun",                       // TUN模式（Layer 3虚拟网卡）
      "tag": "tun-in",                     // 标签名
      "mtu": 1400,                         // 最大传输单元1400字节
      // 为什么MTU是1400而不是1500：
      //   代理协议(REALITY/Trojan/Hysteria)会有额外头部开销
      //   1400给代理头部留了100字节空间，避免分片

      "address": [                         // TUN虚拟网卡的IP地址
        "10.8.0.1/24",                     // IPv4地址(10.8.0.1，子网255.255.255.0)
        "fdfe:dcba:9876::1/126"            // IPv6地址(本地站点地址)
      ],

      "dns_mode": "hijack",                // DNS劫持模式
      // hijack做了什么：
      //   1. 设置手机系统DNS为TUN地址(10.8.0.2)
      //   2. 在系统层面劫持所有发往53端口的DNS包
      //   3. 把所有DNS查询转到sing-box的DNS系统处理
      // 1.14.0-alpha.21加强版：hijack现在自动配置平台级防火墙接管DNS

      "dns_address": [                     // 劫持后DNS包的收件地址
        "10.8.0.2",                        // IPv4 DNS地址
        "fdfe:dcba:9876::2"                // IPv6 DNS地址
      ],
      // 流程：APP查DNS → 发到10.8.0.2:53 → TUN劫持 → sing-box DNS规则匹配 → 返回结果

      "auto_route": true,                  // 自动添加路由规则
      "strict_route": true,                // 严格路由，防止流量绕过TUN
      "route_address_set": [               // 系统路由表层面绕过TUN的IP段
        "cnip",                            // 中国IP段直接走系统网络栈，不进TUN
        "private"                          // 内网IP段直接走系统网络栈
      ],
      // 为什么这是国内速度的关键：
      //   国内域名拿到真实CN IP后，APP连接这个IP时
      //   Android系统一看：这个IP在cnip表里 → 不走TUN虚拟网卡 → 直接走WiFi/4G
      //   sing-box完全没参与这个连接 → 零额外开销 → 等于没开代理的速度
      // 疑惑：那为什么还要在路由规则里写cn→direct？
      // 答：双保险。万一有国内流量进了TUN，路由规则能识别并直连

      "stack": "system"                    // 使用Android系统网络栈（兼容性最好）
    },

    // ── 混合入站：本地HTTP/SOCKS代理（127.0.0.1:7890） ──
    // 说明：给其他APP提供本地代理端口
    // 比如浏览器设代理127.0.0.1:7890就能走sing-box
    {
      "type": "mixed",                     // HTTP + SOCKS5混合代理
      "tag": "mixed-in",                   // 标签名
      "listen": "127.0.0.1",               // 只监听本地，不接受外部连接
      "listen_port": 7890                  // 监听端口
    }
  ],

  // ═══════════════════════════════════════════════
  // 出站（outbounds）—— 流量出口
  // ═══════════════════════════════════════════════
  "outbounds": [
    // ── 直连出站 ──
    {
      "type": "direct",                    // 直连，不经过任何代理
      "tag": "direct",                     // 标签名
      "domain_resolver": "alidns-quic"     // 直连时用阿里DNS解析域名
      // 说明：国内流量和规则集下载都走这个出口
      // 带了domain_resolver，直连域名会用阿里DNS解析
    },

    // ── 拒绝出站 ──
    {
      "type": "block",                     // 直接阻断连接
      "tag": "block"                       // 标签名
      // 说明：给不需要网络访问的流量做黑洞，直接丢弃
    },

    // ── 手动选择器 ──
    {
      "type": "selector",                  // 手动选择节点
      "tag": "smart-proxy",                // 代理出口的标签名
      "outbounds": [                       // 可选节点列表
        "🟢 auto-select",                  // 自动测速选最快
        "🔵 stable-select"                 // 稳定模式选最稳
      ],
      "default": "🟢 auto-select"          // 默认用自动测速
    },

    // ── 自动测速组（🟢） ──
    // 说明：每隔10分钟对所有节点做url测速，选延迟最低的
    // tolerance=100：延迟在第一名100ms内的节点都可以被选中（负载均衡）
    // idle_timeout=30m：30分钟没流量就断开，省资源
    {
      "type": "urltest",                   // URL测速自动选择
      "tag": "🟢 auto-select",             // 标签名
      "outbounds": [                       // 参与测速的14个节点
        "pkpk01", "pkpk02", "pkpk03", "pkpk04", "pkpk05",  // pkpk组5个
        "pkg01", "pkg02", "pkg03", "pkg04", "pkg05",       // pkg组9个（前5）
        "pkg06", "pkg07", "pkg08", "pkg09"                 // pkg组9个（后4）
      ],
      "url": "http://cp.cloudflare.com/generate_204",  // 测速URL（Cloudflare空内容页）
      "interval": "10m0s",               // 每10分钟测一次
      "tolerance": 100,                  // 容忍100ms内的延迟差异(负载均衡)
      "idle_timeout": "30m0s"            // 30分钟无流量自动断开
    },

    // ── 稳定测速组（🔵） ──
    // 说明：更严格的测速标准，适合需要稳定连接的场景
    // tolerance=30：只有延迟差在30ms内的节点才被选
    {
      "type": "urltest",
      "tag": "🔵 stable-select",
      "outbounds": [                     // 同样的14个节点
        "pkpk01", "pkpk02", "pkpk03", "pkpk04", "pkpk05",
        "pkg01", "pkg02", "pkg03", "pkg04", "pkg05",
        "pkg06", "pkg07", "pkg08", "pkg09"
      ],
      "url": "http://cp.cloudflare.com/generate_204",
      "interval": "15m0s",               // 15分钟测一次（更稳重）
      "tolerance": 30,                   // 只接受30ms内的延迟差异
      "idle_timeout": "1h0m0s"           // 1小时无流量才断开
    }
    
    //节点配置
    
  ],

  // ═══════════════════════════════════════════════
  // 路由配置 —— 决定每个连接走直连还是代理
  // ═══════════════════════════════════════════════
  "route": {
    "rules": [
      // 规则①：Cloudflare检测页面 → 直连
      // 用于urltest测速，必须直连才能测出真实延迟
      {
        "domain_suffix": "cp.cloudflare.com",  // Cloudflare连通性检测
        "outbound": "direct"
      },

      // 规则②：嗅探
      // 从TLS ClientHello的SNI字段提取域名
      // 从HTTP请求的Host头提取域名
      // 嗅探结果供后续域名规则使用
      // action=sniff本身不决定出口，只是提取域名
      {
        "action": "sniff"
      },

      // 规则③：DNS劫持
      // 端口53(DNS)或协议是DNS → 劫持到sing-box的DNS系统
      // logical OR：端口53 或 协议是DNS，满足一个就劫持
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "port": 53 },                     // 标准DNS端口
          { "protocol": "dns" }               // 被嗅探识别为DNS的流量
        ],
        "action": "hijack-dns"                // 劫持到DNS系统
      },

      // 规则④：拒绝DoT和mDNS
      // 853=DNS over TLS，5353=组播DNS
      // 防止APP绕过sing-box的DNS劫持
      {
        "port": [853, 5353],
        "action": "reject"
      },

      // 规则⑤：拒绝IPv6（设备无公网v6地址时）
      // logical AND：IPv6 AND 设备没有2000::/3范围的地址(2000::/3是全球单播v6)
      // invert=true：反转匹配——设备没有全球v6地址时匹配
      // 效果：手机没v6 → 自动拒绝所有v6连接，避免超时
      //       手机有v6 → 不匹配，v6正常走
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "ip_version": 6 },                // IPv6流量
          {
            "default_interface_address": "2000::/3",  // 检查默认接口是否有全球v6
            "invert": true                     // 反转：没有全球v6就匹配
          }
        ],
        "action": "reject"                     // 拒绝IPv6连接
      },
      // 疑惑：为什么不直接全局拒绝IPv6？
      // 答：如果以后换了个有IPv6的网络（比如新出的5G套餐）
      //    这条规则会自动放行IPv6。全局拒绝的话要手动改配置

      // 规则⑥：NTP和ICMP → 直连
      {
        "protocol": ["ntp", "icmp"],
        "outbound": "direct"
      },

      // 规则⑦：Google中国站 → 代理
      // google.cn和googleapis.cn虽然在.cn下，但被墙了
      // 这条在.cn→direct规则之前，优先走代理
      {
        "domain_suffix": ["google.cn", "googleapis.cn"],
        "outbound": "smart-proxy"
      },

      // 规则⑧：IP泄露检测站 → 代理
      // 这些站点用来检测你当前IP，走代理隐藏真实IP
      {
        "domain_suffix": [
          "browserleaks.com",    // WebRTC/IP检测
          "ipleak.net",          // IP/DNS泄露检测
          "dnsleaktest.com",     // DNS泄露检测
          "whoer.net",           // 综合信息检测
          "whatleaks.com",       // 泄露检测
          "ip.sb",               // IP查询
          "ipinfo.io",           // IP信息
          "ifconfig.me",         // IP查询
          "ip-api.com"           // IP地理位置
        ],
        "outbound": "smart-proxy"
      },

      // 规则⑨：FCM和Android系统 → 代理
      // Google FCM推送和Android系统服务需要代理
      {
        "rule_set": ["fcm", "Android"],
        "outbound": "smart-proxy"
      },

      // 规则⑩：国外网站规则集 → 代理
      // 涵盖Google/YouTube/Telegram/Instagram/GFW/AI/游戏/流媒体
      {
        "rule_set": [
          "geosite-google",     // Google全系
          "geosite-youtube",    // YouTube
          "telegram",           // Telegram
          "instagram",          // Instagram
          "Google",             // Google补充规则(senshinya)
          "Proxy",              // geosite-geolocation-!cn(非中国)
          "gfw",                // GFW封锁列表
          "ai",                 // AI服务(ChatGPT/Gemini/Claude等)
          "games",              // 游戏平台(Steam/Epic等)
          "GlobalMedia",        // 国际流媒体(Netflix/Disney+等)
          "telegram_ip",        // Telegram服务器IP(senshinya)
          "telegramip"          // Telegram服务器IP(DustinWin)
          // telegram_ip和telegramip有重叠，但双保险不遗漏
        ],
        "outbound": "smart-proxy"
      },

      // 规则⑪：Google系APP包名 → 代理
      // 根据Android APP包名直接判断，连DNS都不用查
      {
        "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.(messenger|group)(\\..*)?)$",
        // 解释：正则匹配以下APP
        //   com.google.android.youtube     → YouTube
        //   com.google.android.apps.maps   → Google Maps
        //   com.google.android.apps.docs   → Google Docs
        //   com.google.android.apps.drive  → Google Drive
        //   app.revanced.android.youtube   → YouTube Revanced
        //   org.telegram.messenger(.xxx)   → Telegram
        //   org.telegram.group             → Telegram X
        "outbound": "smart-proxy"
      },

      // 规则⑫：中国CDN域名 → 直连
      // 与DNS规则③对应，双保险确保这些CDN域名直连
      {
        "domain_suffix": [
          "douyinvod.com", "ibytedtos.com", "pstatp.com",
          "byteimg.com", "bytecdn.com", "snssdk.com",
          "bytedance.com", "toutiao.com", "ixigua.com",
          "volcengine.com", "kuaishou.com", "yximgs.com",
          "bilivideo.com", "hdslb.com", "alicdn.com",
          "aliyuncs.com", "gtimg.com", "360buyimg.com",
          "pinduoduo.com"
        ],
        "outbound": "direct"
      },

      // 规则⑬：中国顶级域名 → 直连
      {
        "domain_suffix": [
          ".cn",
          ".xn--fiqs8s",       // .中国
          ".xn--55qx5d",       // .公司
          ".xn--io0a7i"        // .网络
        ],
        "outbound": "direct"
      },

      // 规则⑭：中国域名/IP规则集 → 直连
      {
        "rule_set": [
          "private",           // 内网IP(192.168.x.x等)
          "cn",                // 中国域名(geosite:cn)
          "cnip",              // 中国IP段
          "microsoft-cn",      // 微软中国
          "apple-cn",          // 苹果中国
          "games-cn",          // 国内游戏
          "networktest"        // 网络检测(测速等)
        ],
        "outbound": "direct"
      },

      // 规则⑮：SponsorBlock → 直连
      { "domain_suffix": "sponsor.ajay.app", "outbound": "direct" },

      // 规则⑯：国内APP → 强制直连
      {
        "package_name": [
          "com.tencent.mm",                  // 微信
          "com.eg.android.AlipayGphone",     // 支付宝
          "com.netease.cloudmusic",          // 网易云音乐
          "com.wwwscn.yuexingbao"            // 月行宝
        ],
        "outbound": "direct"
      },

      // 规则⑰：Apple规则集 → 直连
      // Apple的国际服务(iCloud/App Store等)在国内也能直连(有国内CDN)
      {
        "rule_set": "Apple",
        "outbound": "direct"
      },

      // 规则⑱：Clash模式切换
      // 通过Clash API切换全局模式
      { "clash_mode": "Direct", "outbound": "direct" },
      { "clash_mode": "Global", "outbound": "smart-proxy" },

      // 规则⑲：内网IP → 直连
      // 192.168.x.x、10.x.x.x、172.16-31.x.x等
      { "ip_is_private": true, "outbound": "direct" },

      // 规则⑳：FakeIP范围 → 代理（关键兜底！）
      // 所有拿到198.18.x.x假IP的流量都在这里被送往代理
      // 这是国外流量走到代理的最后一步
      // 前面的国内规则(china/cn/cnip等)应该已经把国内流量拦截掉了
      // 到这里还没被拦截的 = 一定是国外流量 = 走代理
      {
        "ip_cidr": "198.18.0.0/15",          // FakeIP的地址范围
        "outbound": "smart-proxy"             // 走代理
      },

      // 规则㉑：UDP路由选项
      {
        "action": "route-options",
        "udp_disable_domain_unmapping": true, // 关闭UDP域名反向映射
        "udp_connect": true                   // 强制UDP使用connect模式
        // udp_connect的作用：
        //   让每个UDP"连接"都有明确的目标地址，sing-box可以精确路由
        //   代价：不支持向多个目标发UDP的APP（极少）
      },

      // 规则㉒：广告/反欺诈/HTTPDNS → 直接丢弃
      // method=drop：直接丢弃包，连RST都不回
      // 比reject更狠——reject回RST让APP知道你拒绝了
      // drop直接沉默，APP以为网络超时
      {
        "rule_set": ["Ads", "httpDNS", "DNSreject", "anti_fraud"],
        "action": "reject",
        "method": "drop"
      },

      // 规则㉓：特定跟踪域名 → drop
      {
        "domain": [
          "beacon.qq.com",                   // QQ跟踪信标
          "abyss.cyapi.cn",                  // 彩云天气跟踪
          "ad.cyapi.cn",                     // 彩云天气广告
          "gather.colorfulclouds.net"        // 彩云天气数据收集
        ],
        "action": "reject",
        "method": "drop"
      },

      // 规则㉔：广告规则集 → reject
      {
        "rule_set": ["geosite_adguard", "geosite-category-ads-all"],
        "action": "reject"
      },

      // 规则㉕：STUN/QUIC/DTLS → reject
      // STUN：WebRTC用，可能导致真实IP泄露
      // QUIC：代理UDP不稳定，强制走TCP
      // DTLS：WebRTC加密，同STUN
      {
        "protocol": ["stun", "quic", "dtls"],
        "action": "reject"
      },

      // 规则㉖：STUN/TURN/HTTPDNS端口 → reject
      // 进一步封堵可能泄露的UDP端口
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "network": "udp",
            "port": [3478, 5349, 5350, 19302, 10000]  // STUN/TURN常见端口
          },
          { "domain_regex": "^stun\\..+" },           // stun.xxx域名
          { "domain_keyword": ["stun", "turn", "httpdns"] } // 关键词
        ],
        "action": "reject"
      },

      // 规则㉗：最终解析
      // 强制解析所有剩余流量的域名，确保后续路由能看到域名
      {
        "action": "resolve"
      }
    ],

    // ── 远程规则集（30个） ──
    // 每48小时自动从cdn.jsdelivr.net更新
    // 使用http_client: default = 直连下载
    "rule_set": [
      // SagerNet出品(geosite)
      { "type": "remote", "tag": "geosite-category-ads-all", "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-category-ads-all.srs", "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "geosite-google",          "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-google.srs",          "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "geosite-youtube",         "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-youtube.srs",         "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Proxy",                   "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-geolocation-!cn.srs", "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Apple",                   "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-apple.srs",             "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "telegram",                "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-telegram.srs",          "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "instagram",               "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-instagram.srs",         "http_client": "default", "update_interval": "48h0m0s" },

      // DustinWin出品(ruleset_geodata)
      { "type": "remote", "tag": "games",         "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/games.srs",         "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "ai",            "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/ai.srs",            "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "private",       "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/private.srs",       "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "cn",            "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/cn.srs",            "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "microsoft-cn",  "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/microsoft-cn.srs",  "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "apple-cn",      "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/apple-cn.srs",      "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "games-cn",      "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/games-cn.srs",      "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "networktest",   "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/networktest.srs",   "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "telegramip",    "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/telegramip.srs",    "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "cnip",          "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/cnip.srs",          "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Filter",        "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/fakeip-filter.srs", "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Ads",           "url": "https://cdn.jsdelivr.net/gh/DustinWin/ruleset_geodata@sing-box-ruleset/ads.srs",           "http_client": "default", "update_interval": "48h0m0s" },

      // MetaCubeX出品
      { "type": "remote", "tag": "telegram_ip",  "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/telegram.srs",          "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "gfw",          "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/gfw.srs",             "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "GlobalMedia",  "url": "https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-entertainment.srs", "http_client": "default", "update_interval": "48h0m0s" },

      // senshinya出品
      { "type": "remote", "tag": "DNSreject",     "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/AdGuardSDNSFilter/AdGuardSDNSFilter.srs", "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "httpDNS",       "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/BlockHttpDNS/BlockHttpDNS.srs",            "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Google",        "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/Google/Google.srs",                          "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "fcm",           "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/GoogleFCM/GoogleFCM.srs",                    "http_client": "default", "update_interval": "48h0m0s" },
      { "type": "remote", "tag": "Android",       "url": "https://cdn.jsdelivr.net/gh/senshinya/singbox_ruleset@main/rule/Android/Android.srs",                        "http_client": "default", "update_interval": "48h0m0s" },

      // 217heidai出品
      { "type": "remote", "tag": "geosite_adguard", "url": "https://cdn.jsdelivr.net/gh/217heidai/adblockfilters@main/rules/adblocksingbox.srs", "http_client": "default", "update_interval": "48h0m0s" },

      // hwsaya出品
      { "type": "remote", "tag": "anti_fraud", "url": "https://cdn.jsdelivr.net/gh/hwsaya/nothing@main/rules/FuckFZ.json", "http_client": "default", "update_interval": "48h0m0s" }
    ],

    // ── 路由全局设置 ──
    "final": "smart-proxy",                  // 最终兜底：未被任何规则匹配 → 走代理
    "auto_detect_interface": true,           // 自动检测网络接口(WiFi/4G切换自动适配)
    "default_domain_resolver": "alidns-quic" // 路由层解析域名时默认用阿里DNS
  },

  // ═══════════════════════════════════════════════
  // 实验性功能
  // ═══════════════════════════════════════════════
  "experimental": {
    // ── 缓存文件 ──
    // 持久化fakeip映射表和DNS缓存到cache.db
    // 重启sing-box后不需要重新建立，秒恢复
    {
      "cache_file": {
        "enabled": true,                     // 开启缓存文件
        "path": "cache.db",                  // 缓存文件路径
        "cache_id": "cinchov",              // 缓存ID（切换配置时区分不同缓存）
        "store_fakeip": true,                // 保存fakeip域名→假IP映射
        "store_dns": true                    // 保存DNS解析缓存
      }
    },

    // ── Clash API ──
    // 提供与Clash兼容的REST API，可以通过Yacd等面板管理
    {
      "clash_api": {
        "external_controller": "127.0.0.1:9090",  // API监听地址
        "external_ui": "ui",                      // Web面板文件目录
        "default_mode": "rule"                    // 默认规则模式
      }
    },

    // ── Go GC调优 ──
    // gc_percent=100: 默认GC触发阈值(内存翻倍才GC)
    // memory_limit=400MB: 内存软限制，接近时主动GC
    // Android手机上限制内存使用
    {
      "debug": {
        "gc_percent": 100,
        "memory_limit": "400MB"
      }
    }
  }
}

