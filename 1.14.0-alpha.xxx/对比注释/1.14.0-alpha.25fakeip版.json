    // ── pkg09: NaiveProxy (QUIC 模式) ──
    // 与 pkg08 同服务器，但用 QUIC 传输 + BBR 拥塞控制
    // udp_over_tcp: false — QUIC 自带 UDP 支持
    {
      "type": "naive",
      "tag": "pkg09",
      "server": "your-domain.com",
      "server_port": 0000,
      "username": "00000000-0000-0000-0000-000000000002",
      "password": "00000000-0000-0000-0000-000000000002",
      "udp_over_tcp": false,
      "quic": true,
      "quic_congestion_control": "bbr",
      "tls": {
        "enabled": true,
        "server_name": "addons.mozilla.org",
        "certificate": [
          "-----BEGIN CERTIFICATE-----",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "REPLACE_WITH_YOUR_CERT_BASE64_LINE",
          "-----END CERTIFICATE-----"
        ]
      }
    }
  ],

  // ═══════════════════ 路由：Sniff 指哪打哪 ═══════════════════
  // 规则按顺序匹配，一旦命中立即停止。
  // 所以在最前面放例外，中间放主力分流，最后放拒绝。
  "route": {
    "rules": [
      // ── 第 0 层：urltest 测速目标 ──
      // cp.cloudflare.com/generate_204 是 urltest 的测速 URL
      // 必须直连，才能准确测出每个节点的 RTT
      // 如果不加这个规则，它会走 FakeIP → sniff → 无人匹配 → resolve → smart-proxy
      // 这样就变成「通过代理测代理的速」了
      {
        "domain_suffix": "cp.cloudflare.com",
        "outbound": "direct"
      },

      // ── 第 1 层：Sniff 嗅探（最终幻想核心） ──
      // 从每个新连接的前几个字节中抓取域名：
      //   TLS ClientHello → SNI 字段 → 域名
      //   HTTP 请求       → Host 头    → 域名
      //   QUIC ClientHello→ SNI 字段 → 域名
      // 后续所有 rule_set/domain_suffix 匹配都依赖这个 sniff 结果
      {
        "action": "sniff"
      },

      // ── 第 2 层：DNS 劫持 ──
      // 拦截所有发往 :53 端口的 UDP/TCP 流量
      // 以及任何被识别为 dns 协议的流量
      // 交给 sing-box 内置 DNS 引擎处理（走上面的 DNS 规则）
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },

      // ── 第 3 层：阻断 DoT/DoQ ──
      // 拒绝 DNS over TLS（853）和 DNS over QUIC（5353）
      // 这些加密 DNS 请求无法被 hijack-dns 劫持（因为在 TLS 里）
      // 直接拒绝，强制 APP 回退到明文的 :53 DNS（然后被劫持）
      {
        "port": [
          853,
          5353
        ],
        "action": "reject"
      },

      // ── 第 4 层：阻断非本机 IPv6 ──
      // 安卓手机通常同时有 IPv4 和 IPv6
      // IPv6 走代理不稳定（很多节点不支持），而且容易泄露
      // 所以把所有非本地（2000::/3 全球单播）IPv6 流量全部拒绝
      // APP 会自己 fallback 到 IPv4（实测抖音、B站、Telegram 都正常）
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "ip_version": 6
          },
          {
            "default_interface_address": "2000::/3",
            "invert": true
          }
        ],
        "action": "reject"
      },

      // ── 第 5 层：NTP / ICMP 直连 ──
      // NTP 时间同步、ICMP Ping 不需要走代理
      // 注意：sing-box 内置的 NTP 有自己独立的 detour（见上面 ntp 配置）
      // 这条规则处理的是 APP 层面的 NTP 请求
      {
        "protocol": [
          "ntp",
          "icmp"
        ],
        "outbound": "direct"
      },

      // ── 第 6 层：例外代理 — google.cn / googleapis.cn ──
      // 这两个域名是 .cn 后缀，会被下面的 cn 规则集（geosite-cn）捕获
      // 但它们实际上是 Google 服务，在国内被 DNS 污染/劫持
      // 必须走代理才能正常访问 → 所以特意放在 CN 规则集前面
      {
        "domain_suffix": [
          "google.cn",
          "googleapis.cn"
        ],
        "outbound": "smart-proxy"
      },

      // ── 第 7 层：泄露检测站点 → 代理 ──
      // 访问这些站点查看你的出口 IP、DNS 服务器、WebRTC 泄露情况
      // 如果走直连，会暴露你的真实 IP → 必须强制走代理
      {
        "domain_suffix": [
          "browserleaks.com",
          "ipleak.net",
          "dnsleaktest.com",
          "whoer.net",
          "whatleaks.com",
          "ip.sb",
          "ipinfo.io",
          "ifconfig.me",
          "ip-api.com"
        ],
        "outbound": "smart-proxy"
      },

      // ── 第 8 层：FCM / Android 系统服务 → 代理 ──
      // FCM: Firebase Cloud Messaging，Google 推送服务
      // Android: Android 系统连接检测/更新等
      // 国内 Google 服务被墙，必须走代理
      {
        "rule_set": [
          "fcm",
          "Android"
        ],
        "outbound": "smart-proxy"
      },

      // ── 第 9 层：主力代理规则集 ──
      // 所有需要走代理的域名/IP 都在这里匹配：
      //   geosite-google    → Google 全部服务（SagerNet 官方）
      //   geosite-youtube   → YouTube 全部域名（SagerNet 官方）
      //   telegram          → Telegram 域名（SagerNet 官方）
      //   instagram         → Instagram 域名（SagerNet 官方）
      //   Google            → Google 补充规则（senshinya）
      //   Proxy             → geosite-geolocation-!cn（所有非中国域名）
      //   gfw               → GFW 封锁列表（MetaCubeX）
      //   ai                → AI 服务（ChatGPT/Gemini/Claude 等）
      //   games             → 全球游戏平台（Steam/Epic 等）
      //   GlobalMedia       → 全球流媒体（Netflix/Disney+/Spotify 等）
      //   telegram_ip       → Telegram IP 段（DustinWin）
      //   telegramip        → Telegram IP 段（MetaCubeX 备份）
      {
        "rule_set": [
          "geosite-google",
          "geosite-youtube",
          "telegram",
          "instagram",
          "Google",
          "Proxy",
          "gfw",
          "ai",
          "games",
          "GlobalMedia",
          "telegram_ip",
          "telegramip"
        ],
        "outbound": "smart-proxy"
      },

      // ── 第 10 层：包名正则 → 代理（快速通道） ──
      // 对这些 APP 的所有连接直接走代理，跳过 sniff+rule_set 匹配
      // 好处：稳定、更快（省去 sniff 的等待时间）
      // 覆盖：官方 YouTube / YouTube ReVanced / Google Maps / Docs / Drive
      //       Telegram 官方 / Turrit（TG 第三方客户端）
      {
        "package_name_regex": "^(com\\.google\\.android\\.(youtube|apps\\.(maps|docs|drive))|app\\.revanced\\.android\\.youtube|org\\.telegram\\.(messenger|group)(\\..*)?)$",
        "outbound": "smart-proxy"
      },

      // ── 第 11 层：CN 分流 → 直连 ──
      // 所有国内服务走直连：
      //   private       → 局域网（192.168.x.x、10.x.x.x 等）
      //   cn            → 中国域名（geosite-cn，覆盖几乎所有国内网站）
      //   cnip          → 中国 IP 段（GeoIP CN）
      //   microsoft-cn  → 微软中国服务
      //   apple-cn      → Apple 中国 CDN
      //   games-cn      → 国内游戏（王者荣耀、原神国服等）
      //   networktest   → 网络检测（msftconnecttest.com 等）
      {
        "rule_set": [
          "private",
          "cn",
          "cnip",
          "microsoft-cn",
          "apple-cn",
          "games-cn",
          "networktest"
        ],
        "outbound": "direct"
      },

      // ── 第 12 层：兜底直连 — SponsorBlock ──
      // sponsor.ajay.app 是 SponsorBlock API 服务器
      // 不在任何 CN/代理规则集里，但它本身不需要翻墙
      // 直连更快（SponsorBlock 请求频繁但数据量极小）
      {
        "domain_suffix": "sponsor.ajay.app",
        "outbound": "direct"
      },

      // ── 第 13 层：国民应用包名 → 直连（快速通道） ──
      // 微信/支付宝等完全国内服务，走直连快速通道
      // 跳过 sniff+rule_set，直接出站
      {
        "package_name": [
          "com.tencent.mm",
          "com.eg.android.AlipayGphone",
          "com.netease.cloudmusic",
          "com.wwwscn.yuexingbao"
        ],
        "outbound": "direct"
      },

      // ── 第 14 层：Apple 服务 → 直连 ──
      // geosite-apple 包含所有 Apple 域名（App Store/iCloud/Apple Music 等）
      // 因为 apple-cn 只覆盖了中国 CDN，Apple 还有很多国际域名
      // 放在 CN 规则集后面，确保 apple-cn 未覆盖的 Apple 域名也走直连
      {
        "rule_set": "Apple",
        "outbound": "direct"
      },

      // ── 第 15 层：Clash 模式覆盖 ──
      // 通过 Clash API 面板可以一键切换模式
      // Direct 模式：所有未匹配规则走直连
      // Global 模式：所有未匹配规则走代理
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "smart-proxy"
      },

      // ── 第 16 层：IP 级兜底 ──
      // 局域网 IP → 直连（保护内网设备访问）
      // FakeIP 范围（198.18.x.x）→ 代理（没被规则集匹配到但拿到假 IP 的连接）
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "ip_cidr": "198.18.0.0/15",
        "outbound": "smart-proxy"
      },

      // ── 第 17 层：UDP 路由选项 ──
      // udp_disable_domain_unmapping: UDP 不去尝试还原域名（省资源）
      // udp_connect: UDP 用 connected 模式（而不是无连接模式）
      {
        "action": "route-options",
        "udp_disable_domain_unmapping": true,
        "udp_connect": true
      },

      // ── 第 18 层：拒绝广告 / 追踪 / 欺诈 ──
      // 路由层第三次广告过滤（前两次在 DNS 层）
      // method: "drop" — 直接丢弃不发 RST，对方完全不知道被拒绝了
      {
        "rule_set": [
          "Ads",
          "httpDNS",
          "DNSreject",
          "anti_fraud"
        ],
        "action": "reject",
        "method": "drop"
      },

      // ── 第 19 层：特定追踪域名 — drop ──
      // 腾讯 QQ 信标 / 彩云天气追踪 / 广告域名
      // 这些域名绕过了规则集，单独点名
      {
        "domain": [
          "beacon.qq.com",
          "abyss.cyapi.cn",
          "ad.cyapi.cn",
          "gather.colorfulclouds.net"
        ],
        "action": "reject",
        "method": "drop"
      },

      // ── 第 20 层：广告规则集二次过滤 ──
      // 用 AdGuard 和 SagerNet 广告规则做第二次路由层过滤
      // 不用 drop（让对方知道被拒了也无所谓）
      {
        "rule_set": [
          "geosite_adguard",
          "geosite-category-ads-all"
        ],
        "action": "reject"
      },

      // ── 第 21 层：阻断 STUN / QUIC / DTLS ──
      // STUN: WebRTC 使用的 NAT 穿透协议（泄露真实 IP 的主要途径）
      // QUIC: 基于 UDP 的传输层，可能绕过 TUN 的 TCP 分流
      // DTLS: UDP 上的 TLS，同样有泄露风险
      // 拒绝后 APP/浏览器自动回退到 TCP/TLS，不影响功能
      {
        "protocol": [
          "stun",
          "quic",
          "dtls"
        ],
        "action": "reject"
      },

      // ── 第 22 层：WebRTC 泄露深度防御 ──
      // 即使 STUN 协议被第 21 层拦截，
      // 仍可能有通过特定端口/域名的 WebRTC 流量逃逸
      // 这一层用端口+域名正则+关键词组合拦截
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "network": "udp",
            "port": [
              3478,
              5349,
              5350,
              19302,
              10000
            ]
          },
          {
            "domain_regex": "^stun\\..+"
          },
          {
            "domain_keyword": [
              "stun",
              "turn",
              "httpdns"
            ]
          }
        ],
        "action": "reject"
      },

      // ── 终点：resolve ──
      // 当 Sniff 拿到域名、但前面所有规则（包括 CN/代理规则集）都没有匹配时
      // resolve 动作：把域名拿出来，走真实 DNS 再查一次真实 IP
      // 然后根据真实 IP 和 route.final 来决定出站
      // route.final = smart-proxy → 最终走代理
      // 这就是「未知域名默认代理」的策略
      {
        "action": "resolve"
      }
    ],

    // ═══════════════════ 规则集定义（29 个） ═══════════════════
    "rule_set": [
      // ═══ 🧹 去广告类（5 个） ═══
