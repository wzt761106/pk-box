    // 未被任何规则匹配的域名 → resolve 拿真实 IP → 走 smart-proxy
    // 即「未知域名默认代理」策略
    "final": "smart-proxy",

    // 自动检测网络接口（WiFi/移动数据切换时自动适配）
    "auto_detect_interface": true,

    // 路由层解析域名时默认用 alidns-quic（直连阿里 DNS）
    "default_domain_resolver": "alidns-quic"
  },

  // ═══════════════════ 实验性功能 ═══════════════════
  "experimental": {
    // ── 缓存文件 ──
    // 持久化 FakeIP 映射和 DNS 缓存到 cache.db
    // 重启 sing-box 后不需要重新解析域名，FakeIP 映射继续有效
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "your-cache-id",
      "store_fakeip": true,
      "store_dns": true
    },

    // ── Clash API ──
    // 兼容 Clash 生态面板（yacd / metacubexd 等）
    // 监听 127.0.0.1:9090，通过 Web 面板可以切换节点、切换模式、查看连接
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "default_mode": "rule"
    },

    // ── 调试 ──
    // GOGC=100: Go 垃圾回收默认百分比
    // memory_limit=400MB: 内存使用上限（超过强制 GC）
    "debug": {
      "gc_percent": 100,
      "memory_limit": "400MB"
    }
  }
}
