  },

  // =================================================================
  // 8. 实验性功能 (缓存、Web面板、内存限制)
  // =================================================================
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "cinchov",
      "store_fakeip": true,    // 持久化 FakeIP 映射，重启后仍可工作
      "store_dns": true        // 持久化 DNS 缓存
    },
    "clash_api": {             // 兼容 Clash API，可用 Web 面板管理
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",    // 静态网页面板文件放在同目录 ui 文件夹
      "default_mode": "rule"  // 默认规则模式
    },
    "debug": {
      "gc_percent": 100,      // GC 触发百分比，默认 100
      "memory_limit": "400MB" // 软内存限制，防止 OOM
    }
  }
}
