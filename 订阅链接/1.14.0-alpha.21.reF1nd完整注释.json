{
  // ============================================================
  // sing-box 1.14.0-alpha.21.reF1nd 配置文件 - 全版本整合版
  // ============================================================
  // 
  // 包含以下四个版本的完整配置及注释：
  // 1. 本地文件版 (local) - 使用本地 provider 节点
  // 2. 订阅链接版 (remote) - 使用远程订阅 provider 节点 [基础版本]
  // 3. 优化版 (optimized) - 增强规则集和出站管理
  // 4. 修复版 (fixed) - DNS 和路由逻辑修复
  //
  // 【版本差异速览】
  // ┌─────────────────────┬──────────┬──────────┬──────────┬──────────┐
  // │ 差异项              │ 本地文件 │ 订阅链接 │ 优化版   │ 修复版   │
  // ├─────────────────────┼──────────┼──────────┼──────────┼──────────┤
  // │ 节点来源            │ 本地文件 │ 远程订阅 │ 远程订阅 │ 远程订阅 │
  // │ 代理组标签          │ CATCH_ALL│ CATCH_ALL│ sing-box │ sing-box │
  // │ 出站策略            │ 基础     │ 基础     │ 精细     │ 精细     │
  // │ 规则集数量          │ 14       │ 14       │ 23       │ 23       │
  // │ DNS 去广告          │ 弱       │ 弱       │ 强       │ 强       │
  // │ FakeIP 分离         │ 否       │ 否       │ 是       │ 否(修复) │
  // │ 最终出站            │ CATCH_ALL│ CATCH_ALL│ FINAL    │ FINAL    │
  // │ DNS 最终            │ proxy    │ proxy    │ proxy    │ adguard  │
  // └─────────────────────┴──────────┴──────────┴──────────┴──────────┘

  // ============================================================
  // 第一部分：日志配置 (log)
  // 四个版本完全相同
  // ============================================================
  "log": {
    "level": "trace",           // 日志级别：trace(最详细) > debug > info > warn > error > fatal > panic
                                // trace 会记录所有连接细节，适合调试，生产环境建议改为 info 或 warn
    "output": "/dev/null",      // 日志输出路径：/dev/null 表示丢弃所有日志（不记录）
                                // 如需查看日志，可改为 "./sing-box.log" 或留空输出到控制台
    "timestamp": true           // 是否在日志中添加时间戳
  },

  // ============================================================
  // 第二部分：DNS 配置 (dns)
  // 这是核心模块，负责域名解析的策略分流
  // ============================================================
  "dns": {
    // ----------------------------------------------------------
    // DNS 服务器定义
    // ----------------------------------------------------------
    "servers": [
      // --- hosts 类型服务器：本地静态域名解析 ---
      // 四个版本完全相同
      {
        "type": "hosts",                    // hosts 类型：类似系统 /etc/hosts 文件
        "tag": "dns_hosts",                 // 标签名，供其他配置引用
        "predefined": {                     // 预定义的静态域名-IP映射表
          // ---------- Google FCM 推送服务域名 ----------
          // 这些是 Android GCM/FCM 推送服务的关键域名
          // 包含主域名和 alt1-alt8 备用域名
          // 同时提供 IPv6 (2404:/2607:/2a00:开头) 和 IPv4 地址
          "mtalk.google.com": [
            "2404:6800:4008:c07::bc",       // IPv6 地址 (亚洲区域)
            "2404:6800:4008:c1b::bc",
            "2404:6800:4008:c15::bc",
            "2404:6800:4008:c05::bc",
            "2404:6800:4008:c19::bc",
            "2404:6800:4008:c01::bc",
            "2607:f8b0:4023:1c05::bc",      // IPv6 地址 (美洲区域)
            "2607:f8b0:400e:c09::bc",
            "142.250.107.188",              // IPv4 地址
            "142.251.170.188",
            "108.177.125.188",
            "142.251.10.188",
            "64.233.186.188",
            "74.125.206.188"
          ],
          "alt1-mtalk.google.com": [
            "2607:f8b0:4023:1c05::bc",
            "2a00:1450:400b:c02::bc",       // IPv6 地址 (欧洲区域)
            "74.125.200.188"
          ],
          "alt2-mtalk.google.com": "192.178.220.188",  // 单个地址可以不用数组
          "alt3-mtalk.google.com": [
            "2607:f8b0:4023:2009::bc",
            "2607:f8b0:4023:100f::bc",
            "74.125.131.188"
          ],
          "alt4-mtalk.google.com": "209.85.144.188",
          "alt5-mtalk.google.com": [
            "2607:f8b0:4003:c0a::bc",
            "2a00:1450:4025:c01::bc",
            "74.125.126.188"
          ],
          "alt6-mtalk.google.com": "142.250.115.188",
          "alt7-mtalk.google.com": [
            "2607:f8b0:4024:c0d::bc",
            "2404:6800:4003:c06::bc",
            "192.178.131.188"
          ],
          "alt8-mtalk.google.com": "172.253.132.188",
          
          // ---------- Google 下载服务 ----------
          // 使用国内 CDN IP 加速下载 (180.163.x.x 是上海电信 CDN)
          "dl.google.com": "180.163.151.161",
          "dl.l.google.com": "180.163.150.33",
          
          // ---------- DNS 服务器本身的域名解析 ----------
          // 这是鸡生蛋蛋生鸡问题的解决方案：
          // DNS 服务器需要通过域名访问，但解析域名又需要 DNS 服务器
          // 这里预设 IP 地址，打破循环依赖
          // 每个 DNS 服务都配备了多条 IP 以提高可用性
          "dns.alidns.com": [               // 阿里 DNS (DoQ)
            "223.5.5.5",                     // 阿里 DNS 主
            "223.6.6.6"                      // 阿里 DNS 备
          ],
          "doh.pub": [                      // DNSPod (DoH)
            "1.12.12.21",
            "120.53.53.53"
          ],
          "dns.google": [                   // Google DNS (DoH) - 需代理
            "8.8.8.8",
            "8.8.4.4"
          ],
          "dns.quad9.net": [               // Quad9 DNS (DoH) - 需代理
            "149.112.112.112",
            "9.9.9.9"
          ],
          "cloudflare-dns.com": [          // Cloudflare DNS (DoH3) - 需代理
            "104.16.248.249",
            "104.16.249.249"
          ],
          
          // ---------- 规则集/配置更新相关域名 ----------
          // 预设 IP 确保规则集能正常下载
          "raw.githubusercontent.com": [    // GitHub 文件直链
            "185.199.108.133",
            "185.199.109.133",
            "185.199.110.133",
            "185.199.111.133"
          ],
          "cdn.jsdelivr.net": [            // jsDelivr CDN (可能需要代理)
            "104.16.89.20",
            "104.16.90.20"
          ]
        }
      },

      // --- 国内 DNS 服务器 ---
      {
        "type": "https",                    // DNS over HTTPS (DoH)
        "tag": "tx_dns",                    // 腾讯 DNS (DNSPod)
        "domain_resolver": "dns_hosts",     // 用 hosts 解析 doh.pub 的 IP，避免循环依赖
        "server": "doh.pub"                 // 实际 DoH 地址: https://doh.pub/dns-query
      },
      {
        "type": "quic",                     // DNS over QUIC (DoQ) - 基于 UDP，延迟更低
        "tag": "ali_dns",                   // 阿里 DNS
        "domain_resolver": "dns_hosts",
        "server": "dns.alidns.com"          // 实际 DoQ 地址: quic://dns.alidns.com
      },

      // --- 国外 DNS 服务器 (需要代理) ---
      // 【版本差异】本地文件和订阅链接版使用 "📦 CATCH_ALL" 作为 detour
      // 【版本差异】优化版和修复版使用 "📦 sing-box" 作为 detour
      {
        "type": "https",
        "tag": "google_dns",
        "detour": "📦 sing-box",            // 【版本差异】通过代理出站访问
                                            // 本地/订阅版: "📦 CATCH_ALL"
        "domain_resolver": "dns_hosts",
        "server": "dns.google"              // https://dns.google/dns-query
      },
      {
        "type": "https",
        "tag": "quad9_dns",
        "detour": "📦 sing-box",            // 同上版本差异
        "domain_resolver": "dns_hosts",
        "server": "dns.quad9.net"           // https://dns.quad9.net/dns-query
      },
      {
        "type": "h3",                       // DNS over HTTP/3 (DoH3) - 基于 QUIC
        "tag": "cloudflare_dns",
        "detour": "📦 sing-box",            // 同上版本差异
        "domain_resolver": "dns_hosts",
        "server": "cloudflare-dns.com"      // https://cloudflare-dns.com/dns-query
      },

      // ---【修复版新增】AdGuard DNS ---
      // 用于最终兜底 DNS，自带广告过滤
      // 仅存在于修复版
      {
        "type": "udp",                      // 传统 UDP DNS (端口53)
        "tag": "adguard-dns",
        "detour": "📦 sing-box",            // 需要代理访问
        "domain_resolver": "dns_hosts",
        "server": "dns.adguard.com",        // AdGuard DNS: 94.140.14.14 / 94.140.15.15
        "server_port": 53
      },

      // --- DNS 服务器组 (负载均衡/故障转移) ---
      {
        "type": "group",
        "tag": "direct_server",             // 国内直连 DNS 组
        "servers": [
          "ali_dns",                        // 阿里 DoQ (优先)
          "tx_dns"                          // 腾讯 DoH (备用)
        ]
        // 默认使用第一个服务器，如果失败则尝试下一个
      },
      {
        "type": "group",
        "tag": "proxy_server",              // 代理 DNS 组
        "servers": [
          "google_dns",                     // Google DoH (优先)
          "quad9_dns",                      // Quad9 DoH
          "cloudflare_dns"                  // Cloudflare DoH3
        ]
      },

      // --- FakeIP 服务器 ---
      // FakeIP 机制：为需要代理的域名返回虚假 IP (198.18.0.0/15)
      // 优点：避免 DNS 泄露，支持基于 IP 的路由规则
      // 缺点：可能导致部分应用异常
      {
        "type": "fakeip",
        "tag": "fakeip_server",
        "inet4_range": "198.18.0.0/15",     // FakeIP 的 IPv4 地址池 (RFC 2544 保留段)
        "inet6_range": "fc00::/18"          // FakeIP 的 IPv6 地址池 (唯一本地地址)
      }
    ],

    // ----------------------------------------------------------
    // DNS 规则 - 决定查询使用哪个 DNS 服务器
    // 规则按顺序匹配，命中即停止
    // ----------------------------------------------------------
    "rules": [
      // ---【优化版/修复版新增】广告域名直接返回空解析 ---
      // 在 DNS 层面屏蔽广告，比路由层拦截更高效
      {
        "rule_set": [
          "geosite-category-ads-all",       // sing-geosite 的广告分类
          "geosite_adguard"                  // 额外的 AdGuard 过滤规则
        ],
        "action": "predefined",              // 返回预定义响应
        "rcode": "NOERROR"                   // 返回空结果(查询成功但无记录)，让应用认为域名不存在
      },

      // --- Google FCM 和相关域名强制使用 hosts ---
      // 使用预设的 IP 地址，确保推送服务稳定连接
      {
        "domain": [
          "mtalk.google.com",
          "alt1-mtalk.google.com",
          "alt2-mtalk.google.com",
          "alt3-mtalk.google.com",
          "alt4-mtalk.google.com",
          "alt5-mtalk.google.com",
          "alt6-mtalk.google.com",
          "alt7-mtalk.google.com",
          "alt8-mtalk.google.com",
          "dl.google.com",                   // Google 下载服务
          "dl.l.google.com"
        ],
        "server": "dns_hosts"               // 使用 hosts 中预设的 IP
      },

      // ---【修复版新增】Google 连接检查域名强制使用 FakeIP ---
      // 确保 Google 服务的心跳检测走代理
      {
        "domain_suffix": "connectivitycheck.gstatic.com",
        "server": "fakeip_server"
      },

      // --- Clash 模式切换 ---
      {
        "clash_mode": "Global",             // Clash API 切换为全局模式时
        "server": "proxy_server"            // 所有 DNS 查询走代理
      },
      {
        "clash_mode": "Direct",             // Clash API 切换为直连模式时
        "server": "direct_server"           // 所有 DNS 查询走国内
      },

      // --- 屏蔽特定类型的 DNS 查询 ---
      // SVCB/HTTPS 记录用于 ECH/ESNI，可能暴露访问域名
      // PTR 记录用于反向 DNS 查询，通常无用
      {
        "query_type": [
          "SVCB",                           // 服务绑定记录
          "HTTPS",                          // HTTPS 服务记录
          "PTR"                             // 反向指针记录
        ],
        "action": "predefined",
        "rcode": "NOERROR"                  // 返回空结果，阻止这些查询
      },

      // ---【仅在本地文件和订阅链接版本】特定条件下的广告过滤 ---
      // 当没有启用 AllowAds 模式时，阻止广告域名
      // 优化版和修复版已移除(用上面的 rule_set 替代)
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",       // 是否为允许广告模式
            "invert": true                  // invert=true 表示非 AllowAds 模式
          },
          {
            "domain": [
              "a0.app.xiaomi.com",          // 小米广告域名
              "appversion.115.com"          // 115网盘更新域名
            ],
            "rule_set": "geosite-category-ads-all"
          }
        ],
        "action": "predefined",
        "rcode": "NOERROR"
      },

      // --- 特定国内服务和规则集使用直连 DNS ---
      // 四个版本都有，逻辑相同
      {
        "domain_suffix": [
          "market.xiaomi.com",              // 小米应用商店
          "lancache.steamcontent.com",      // Steam 局域网缓存
          "tracking.miui.com",             // MIUI 跟踪(被错误拦截会导致问题)
          "steamserver.net"                 // Steam 服务器
        ],
        "rule_set": [
          "cn",                             // sing-geosite 中国域名列表
          "private"                         // 私有/局域网域名
        ],
        "server": "direct_server"           // 使用国内 DNS 解析
      },

      // ---【优化版专属】已知代理域名使用 FakeIP ---
      // 将这些域名的 DNS 查询直接返回 FakeIP，实现 DNS 与代理的无缝衔接
      // 其他版本没有此规则，走后续的通配规则
      {
        "rule_set": [
          "geosite-google",
          "geosite-youtube",
          "geosite-telegram",
          "geosite-twitter",
          "geosite-github",
          "geosite-microsoft",
          "geosite-apple",
          "geosite-bahamut",
          "Proxy",
          "gfw"
        ],
        "server": "fakeip_server"           // 返回 FakeIP，后续路由根据 FakeIP 段分流
      },

      // ---【版本差异】通配规则 ---
      // 优化版和修复版：先尝试直连 DNS
      {
        "action": "evaluate",              // "evaluate" 是一个特殊动作
        "server": "direct_server"          // 【修复版】使用直连 DNS 进行尝试性解析
                                            // 【优化版】也使用 direct_server
                                            // 【本地/订阅版】使用 proxy_server
                                            // 
                                            // 注意：evaluate 的具体行为取决于 sing-box 版本
                                            // 通常用于在最终决策前进行一次评估查询
                                            // 修复版改为 direct_server 是为了减少代理 DNS 的负担
      },
      
      // --- 匹配响应规则 ---
      // 当 DNS 服务器本身被匹配时(如通过规则集)，返回响应
      {
        "match_response": true,
        "action": "respond"
      }
    ],

    // --- DNS 最终兜底策略 ---
    // 【版本差异】
    // 本地文件版/订阅链接版/优化版: "proxy_server" (未匹配的域名走代理 DNS)
    // 修复版: "adguard-dns" (使用 AdGuard DNS 作为最终解析，自带广告过滤)
    "final": "adguard-dns",                 // 【修复版】AdGuard DNS 兜底
                                            // 其他版本: "proxy_server"
    
    "strategy": "prefer_ipv4",              // 优先使用 IPv4 地址
                                            // 可选: "prefer_ipv6", "ipv4_only", "ipv6_only"
    
    "cache_capacity": 65536,               // 【优化版/修复版】DNS 缓存容量 65536 条
                                            // 【本地/订阅版】4096 条
                                            // 更大的缓存能减少重复查询，但占用更多内存
    
    "optimistic": {                         // DNS 乐观缓存
      "enabled": true,                      // 启用乐观缓存
      "timeout": "120h0m0s"                 // 缓存有效期 120 小时 (5天)
                                            // 在缓存过期前会尝试后台刷新
    }
  },

  // ============================================================
  // 第三部分：HTTP 客户端配置 (http_clients)
  // 四个版本相同(除 detour 标签差异)
  // ============================================================
  "http_clients": [
    {
      "tag": "direct_client",              // 直连 HTTP 客户端
      "version": 2,                         // HTTP/2
      // stream_receive_window: HTTP/2 流接收窗口大小
      // 0 表示使用 Go 默认值 (通常是 16KB-32KB)
      // connection_receive_window: HTTP/2 连接接收窗口大小
      // 0 表示使用 Go 默认值
      "stream_receive_window": 0,
      "connection_receive_window": 0
    },
    {
      "tag": "proxy_client",               // 代理 HTTP 客户端 (用于下载规则集等)
      "version": 2,
      // 【版本差异】
      // 本地/订阅版: "📦 CATCH_ALL"
      // 优化版/修复版: "📦 sing-box"
      "detour": "📦 sing-box",              // 通过代理出站
      "stream_receive_window": 0,
      "connection_receive_window": 0
    }
  ],

  // ============================================================
  // 第四部分：入站配置 (inbounds)
  // 四个版本完全相同
  // ============================================================
  "inbounds": [
    {
      "type": "redirect",                  // 透明代理 (REDIRECT/TPROXY)
      "tag": "redirect-in",
      "listen": "::",                      // 监听所有 IPv6 和 IPv4 地址
      "listen_port": 7897                  // 透明代理端口 (iptables/nftables 转发到这)
    },
    {
      "type": "mixed",                     // 混合代理 (HTTP + SOCKS5)
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 7890                  // 系统代理端口 (浏览器/应用设置这个代理)
    },
    {
      "type": "tun",                       // TUN 虚拟网卡 (最彻底的代理方式)
      "tag": "tun-in",
      "interface_name": "tun0",           // 虚拟网卡名称
      "mtu": 9000,                        // 最大传输单元 (9000 是巨型帧，减少分片)
      "address": [
        "172.19.0.1/30",                  // IPv4 地址段 (172.19.0.1 是网关)
        "fdfe:dcba:9876::1/126"           // IPv6 地址段
      ],
      "auto_route": true,                  // 自动添加路由规则，劫持系统流量
      "auto_redirect": true,              // 自动配置透明代理规则
      "strict_route": true,               // 严格路由模式，防止路由泄漏
      "stack": "system"                    // 使用系统网络栈 (也可选 "gvisor" 用户空间栈)
    }
  ],

  // ============================================================
  // 第五部分：出站配置 (outbounds)
  // 这是代理链的出口，定义了所有的出站策略
  // ============================================================
  "outbounds": [
    // ---------- 最终兜底选择器 ----------
    // 【优化版/修复版新增】提供最终出站的精细控制
    {
      "type": "selector",                  // 手动选择器类型
      "tag": "🚦 FINAL",
      "outbounds": [
        "📦 sing-box",                     // 代理 (优化版/修复版使用 sing-box 标签)
        "🇨🇳 DIRECT",                      // 国内直连
        "❌ REJECT-DROP"                   // 拒绝连接
      ],
      "providers": null,
      "default": "❌ REJECT-DROP",         // 默认拒绝所有未匹配的连接 (安全优先)
      "interrupt_exist_connections": true  // 切换出站时中断已有连接
    },

    // ---------- 拒绝出站 ----------
    // 【优化版/修复版新增】
    {
      "type": "block",                     // block 类型：直接拒绝所有连接
      "tag": "❌ REJECT-DROP"
    },

    // ---------- 主代理选择器 ----------
    // 【版本差异】标签名不同
    {
      "type": "selector",
      // 本地文件版/订阅链接版: "📦 CATCH_ALL"
      // 优化版/修复版: "📦 sing-box"
