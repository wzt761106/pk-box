        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-geolocation-!cn.srs",
        "http_client": "direct_client",
        "update_interval": "48h0m0s"
      }
    ],

    // --- 路由最终出站 ---
    // 【版本差异】
    // 本地文件版/订阅链接版: "📦 CATCH_ALL"
    // 优化版/修复版: "🚦 FINAL"
    "final": "🚦 FINAL",

    // --- 高级路由选项 ---
    "find_process": true,                  // 启用进程查找 (支持 package_name 匹配)
    "auto_detect_interface": true,         // 自动检测网络接口
    "default_domain_resolver": "direct_server",  // 默认域名解析器
    "default_http_client": "direct_client",       // 默认 HTTP 客户端
    "default_domain_match_strategy": "prefer_fqdn" // 域名匹配策略优先使用完整域名(FQDN)
  },

  // ============================================================
  // 第八部分：实验性功能 (experimental)
  // 四个版本完全相同
  // ============================================================
  "experimental": {
    // --- 缓存文件 ---
    "cache_file": {
      "enabled": true,
      "path": "./cache.db",               // 缓存数据库路径
      "store_fakeip": true,               // 存储 FakeIP 映射到缓存 (重启后保留)
      "store_dns": true                   // 存储 DNS 缓存到文件 (重启后保留)
    },
    // --- Clash API (兼容 Clash 面板) ---
    "clash_api": {
      "external_controller": "[::]:9090", // API 监听地址和端口
                                           // [::] 表示监听所有 IPv4 和 IPv6
      "external_ui": "ui"                 // Web UI 文件目录 (如 Yacd/Clash-dashboard)
    },
    // --- 调试选项 ---
    "debug": {
      "gc_percent": 100,                   // 垃圾回收触发百分比 (Go GC)
                                           // 100 是默认值，增大可减少 GC 频率但占用更多内存
      "memory_limit": "200MB"              // 软内存限制 (Go soft memory limit)
                                           // 达到此限制时会主动触发 GC
    },
    // --- 统一延迟测试 ---
    // 在 URLTest 模式下使用统一的延迟测试方法
    "urltest_unified_delay": true
  }
}

// ============================================================
// 附录：版本差异详细说明
// ============================================================
//
// 【本地文件版 vs 订阅链接版】
//   唯一区别在于 providers 的类型：
//   - 本地文件版: "type": "local", 从本地 JSON 文件加载节点
//   - 订阅链接版: "type": "remote", 从远程 URL 下载节点配置
//   订阅链接版是基础版本，其他版本在其基础上演化
//
// 【订阅链接版 -> 优化版 主要变更】
//   1. 标签重构: "📦 CATCH_ALL" -> "📦 sing-box", "🇨🇳 All Nodes" -> "🇨🇳 DIRECT"
//   2. 出站管理: 新增 "🚦 FINAL" 最终选择器和 "❌ REJECT-DROP" 拒绝出站
//   3. DNS 增强: 新增 AdGuard 规则集过滤广告域名
//   4. FakeIP 分离: 将已知代理域名独立使用 FakeIP，实现 DNS 泄露防护
//   5. 规则集扩展: 从 14 个扩展到 23 个，覆盖更精细
//   6. 应用分流: 新增微信/钉钉/支付宝等国内应用直连规则
//   7. 缓存优化: DNS 缓存从 4096 提升到 65536
//
// 【优化版 -> 修复版 主要变更】
//   1. DNS 最终策略: "proxy_server" -> "adguard-dns" (AdGuard DNS 兜底)
//   2. 移除 FakeIP 分离: DNS 规则中不再将代理域名指向 fakeip_server
//      而是走后续的 evaluate 规则
//   3. Google FCM 增强: 默认使用代理("📦 sing-box")，确保推送稳定
//   4. Apple 服务: 添加默认直连("🇨🇳 DIRECT")
//   5. 彩云天气: gather.colorfulclouds.net 改为走代理
//   6. Google 连通性检测: 指定走代理出站
//   7. DNS evaluate 优化: 使用 direct_server 替代 proxy_server
//      减少代理 DNS 的查询负担
//
// 【已知问题和注意事项】
//   1. providers 中 "你的订阅链接" 需要替换为实际的订阅 URL
//   2. 本地文件版需要确保 "./providers/config.json" 文件存在
//   3. "interrupt_exist_connections" 有拼写错误(正确的可能是 interrupt_existing_connections)
//      但 sing-box 可能同时兼容两种写法
//   4. FakeIP 段 198.18.0.0/15 是 RFC 2544 保留地址，通常不会冲突
//   5. 规则集 URL 使用 jsDelivr CDN，国内可能下载缓慢或失败
//      可以考虑替换为镜像地址
//   6. AdGuard DNS (dns.adguard.com) 在某些网络环境下可能被屏蔽
//   7. QUIC (DoQ/H3) 协议在某些网络环境下可能被 QoS 限制
//   8. cache_capacity 65536 可能对低内存设备不友好
//   9. GC percent 100 和 memory limit 200MB 适合大多数场景
//      可根据设备配置调整
//
// ============================================================

