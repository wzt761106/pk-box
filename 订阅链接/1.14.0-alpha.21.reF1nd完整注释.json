  // ============================================================
  // 第六部分：节点提供者 (providers)
  // 【版本差异】本地文件 vs 远程订阅
  // ============================================================
  "providers": [
    {
      // --- 本地文件版 ---
      // "type": "local",                  // 从本地文件加载节点
      // "tag": "local_nodes",
      // "path": "./providers/config.json",// 节点配置文件路径
      // --- 优化版/修复版 ---
      "type": "remote",                    // 从远程 URL 加载节点
      "tag": "my_nodes",
      "url": "你的订阅链接",               // <--- 请替换为实际的订阅链接
      "path": "./providers/my_nodes.json", // 下载后的本地缓存路径
      "http_client": "direct_client",      // 【版本差异】订阅/优化/修复版使用直连客户端下载
                                            // 本地版没有此字段
      "update_interval": "24h0m0s",        // 每24小时自动更新订阅
      "health_check": {                    // 节点健康检查
        "enabled": true,
        "url": "https://www.gstatic.com/generate_204",  // Google 的连通性检测地址
                                                         // 返回 HTTP 204 表示通
        "interval": "1h0m0s",              // 每1小时检查一次
        "timeout": "3s"                    // 超时时间3秒
      }
    }
  ],

  // ============================================================
  // 第七部分：路由配置 (route)
  // 核心规则引擎，决定流量的最终出站
  // ============================================================
  "route": {
    "rules": [
      // --- 规则 1: 域名嗅探 ---
      // 对 TLS/HTTP 流量进行 SNI/Host 嗅探，获取真实域名
      // 这对于基于域名的路由规则至关重要
      { "action": "sniff" },

      // --- 规则 2: 绕过本地代理端口 ---
      // 防止 sing-box 自身流量被代理(避免循环)
      { "ip_cidr": "127.0.0.0/8", "port": [7897, 7898], "action": "bypass" },

      // --- 规则 3: ICMP 直连 ---
      // ping 等 ICMP 协议直接走直连
      { "network": "icmp", "outbound": "direct" },

      // --- 规则 4:【版本位置不同】IPv6 非公网地址拒绝 ---
      // 拒绝非公网 IPv6 地址的连接
      // 优化版/修复版将此规则移到了更后的位置
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "ip_version": 6 },             // IPv6
          { "default_interface_address": "2000::/3", "invert": true }  // 非公网 IPv6 (2000::/3 是公网范围)
        ],
        "action": "reject"
      },

      // --- 规则 5: DNS 劫持 ---
      // 将发往其他 DNS 服务器的请求劫持到 sing-box 内置 DNS
      { "protocol": "dns", "action": "hijack-dns" },

      // --- 规则 6-7: Clash 模式切换 ---
      { "clash_mode": "Global", "outbound": "GLOBAL" },
      { "clash_mode": "Direct", "outbound": "direct" },

      // --- 规则 8:【优化版/修复版调整位置】国内应用直连 ---
      // 将国内主流应用强制走直连，避免被错误代理
      {
        "package_name": [                  // Android 应用包名匹配 (需要 find_process: true)
          "com.tencent.mm",                // 微信
          "com.tencent.mobileqq",          // QQ
          "com.alibaba.android.rimet",     // 钉钉
          "com.eg.android.AlipayGphone",   // 支付宝
          "com.netease.cloudmusic"         // 网易云音乐
        ],
        "outbound": "direct"
      },

      // --- 规则 9:【优化版/修复版新增】微信 DNS 直连 ---
      // 微信可能使用特定 DNS，确保直连
      { "domain": "dns.weixin.qq.com.cn", "outbound": "direct" },

      // --- 规则 10: 国内服务和规则集直连 ---
      // 四个版本都有，逻辑相同
      {
        "domain_suffix": [                 // 特定域名后缀直连
          "market.xiaomi.com",             // 小米应用商店 (直连更快)
          "lancache.steamcontent.com",     // Steam 局域网缓存
          "tracking.miui.com",            // MIUI 跟踪 (不能拦截，否则影响系统)
          "steamserver.net"                // Steam 服务器
        ],
        "rule_set": [                      // 规则集补充
          "cn",                            // 中国域名
          "private",                       // 私有域名
          // --- 优化版/修复版新增 ---
          "cnip",                          // 中国 IP
          "apple-cn",                      // Apple 中国服务
          "microsoft-cn",                  // Microsoft 中国服务
          "google-cn",                     // Google 中国服务
          "games-cn"                       // 游戏平台中国服务
        ],
        "outbound": "direct"
      },

      // --- 规则 11: 广告域名拒绝 ---
      // 在路由层面拒绝广告连接 (DNS 层面已屏蔽，这是第二道防线)
      {
        // 本地/订阅版: 仅使用 geosite-category-ads-all 和少数特定域名
        // 优化版/修复版: 使用多个规则集增强拦截
        "rule_set": [
          "geosite-category-ads-all",
          "geosite_adguard",               // AdGuard 规则
          "Ads",                           // 额外广告规则
          "DNSreject"                      // DNS 拒绝规则
        ],
        // 本地/订阅版: 还包含以下域名
        // "domain": ["abyss.cyapi.cn", "ad.cyapi.cn", "gather.colorfulclouds.net"],
        "action": "reject",
        "method": "drop"                   // 直接丢弃数据包 (无响应)，比 reject 更隐蔽
      },

      // --- 规则 12:【修复版】特定域名处理 ---
      // 将彩云天气相关域名拆分处理
      {
        "domain": [
          "abyss.cyapi.cn",               // 可能是广告/跟踪域名 -> 拒绝
          "ad.cyapi.cn"                    // 明确的广告域名 -> 拒绝
        ],
        "action": "reject",
        "method": "drop"
      },
      // gather.colorfulclouds.net 被移到后面走代理
      {
        "domain": "gather.colorfulclouds.net",  // 彩云天气数据收集 -> 走代理
        "outbound": "📦 sing-box"
      },

      // --- 规则 13:【修复版新增】Google 连接检查 ---
      // 确保 Google 服务连通性检测走代理
      {
        "domain_suffix": "connectivitycheck.gstatic.com",
        "outbound": "📦 sing-box"
      },

      // --- 规则 14: FakeIP 段路由 ---
      // 将 FakeIP 地址段的流量强制走代理
      // 【仅优化版有此规则】
      { "ip_cidr": "198.18.0.0/15", "outbound": "📦 sing-box" },

      // --- 规则 15: 已知代理域名/规则集 ---
      // 这些域名必须走代理
      {
        "rule_set": [
          "geosite-google",               // Google 全系
          "geosite-youtube",              // YouTube
          "geosite-twitter",              // Twitter/X
          "geosite-github",               // GitHub (国内访问不稳定)
          "geosite-microsoft",            // Microsoft (部分服务被墙)
          "geosite-apple",                // Apple (外区服务需代理)
          "geosite-telegram",             // Telegram (完全被墙)
          "geosite-bahamut",              // 巴哈姆特 (台湾游戏论坛，被墙)
          "Proxy",                         // 通用代理规则
          "gfw",                          // GFW 列表
          "telegramip",                    // Telegram IP 段
          "telegram_ip"                    // Telegram IP (另一来源)
        ],
        "outbound": "📦 sing-box"
        // 本地/订阅版: "📦 CATCH_ALL"
      },

      // --- 规则 16:【优化版/修复版新增】特定应用走代理 ---
      // 通过 Android 包名强制代理
      {
        "package_name": [
          "org.telegram.group",           // Telegram
          "org.telegram.messenger",
          "org.telegram.messenger.beta",
          "com.google.android.youtube",   // YouTube
          "app.revanced.android.youtube"   // YouTube ReVanced
        ],
        "outbound": "📦 sing-box"
      },

      // --- 规则 17: Google FCM 分流 ---
      // FCM 使用独立的选择器，方便单独调整策略
      {
        "type": "logical",
        "mode": "or",                      // 满足任一条件
        "rules": [
          {
            "domain_keyword": [            // 域名关键字匹配
              "mtalk.google.com",          // FCM 主域名
              "dl.google",                 // Google 下载
              "dl.l.google"
            ]
          },
          { "port": 5228 }                 // FCM 标准端口 5228
        ],
        "outbound": "📬 Google FCM"        // 使用 FCM 专用选择器
      },

      // --- 规则 18: 解析步骤 ---
      // 在所有基于域名的规则之后，进行 DNS 解析
      // 之后的规则可以基于 IP 地址进行匹配
      { "action": "resolve" },

      // --- 规则 19-20: 最终 IP 分流 ---
      // DNS 解析后，根据 IP 地址进行最终分流
      { "rule_set": "cnip", "outbound": "direct" },        // 中国 IP 直连
      { "rule_set": "Proxy", "outbound": "📦 sing-box" }    // 代理 IP 走代理
      // 本地/订阅版: 使用 "geosite-geolocation-!cn" 规则集
      // 优化版/修复版: 使用 "Proxy" 规则集
    ],

