    "final": "PROXY",
    // 任何路由规则未匹配 → PROXY(代理)
    // 疑问: 这是不是太重了? 国内网站也代理?
    // 回答: 前面已有12条规则覆盖绝大多数情况
    //       (本地域名、私有IP、中国域名/IP、广告...)
    //       到final这一步的都是"规则集之外"的
    //       走PROXY是最安全的选择

    "auto_detect_interface": true
    // 自动检测手机的默认网络接口(WiFi还是蜂窝)
    // 疑问: 这个和 network_type 有什么区别?
    // 回答: auto_detect_interface 是底层: "手机现在用哪个网卡?"
    //       network_type 是上层: "根据网卡类型选DNS"
    //       必须开 auto_detect_interface 才能用 network_type
  },

  // =========================================================================
  // 实验性功能
  // =========================================================================
  "experimental": {
    "clash_api": {
      // Clash API: 提供HTTP RESTful API, 兼容Clash面板
      // 疑问: sing-box为什么要兼容Clash?
      // 回答: Clash生态有大量成熟的面板(Web UI)
      //       如 Yacd/MetaCubeXd/Dashboard
      //       兼容API = 能直接用这些面板, 不用自己写
      "external_controller": "127.0.0.1:9090",
      // 只监听本机, 不对外开放
      "external_ui": "ui",
      // 面板文件存放目录(相对于配置目录)
      "external_ui_download_url": "https://cdn.jsdelivr.net/gh/MetaCubeX/metacubexd@gh-pages/metacubexd.zip",
      // 自动下载 MetaCubeXd 面板(最流行的Clash面板之一)
      "external_ui_download_detour": "PROXY",
      // 面板zip走代理下载
      // 疑问: 规则集改DIRECT了, 为什么面板还走PROXY?
      // 回答: 面板只下载一次, 失败率低
      //       而且面板zip比较大, jsdelivr可能限速
      //       走代理通常更快
      "secret": "屏蔽的Secret",
      // [!] API认证密钥
      // 客户端需 HTTP头: Authorization: Bearer xxx
      // 疑问: 只监听127.0.0.1, 还需要密码?
      // 回答: 本机App(如浏览器)访问不需要密码
      //       但某些情况下(端口转发等)其他人可能访问
      //       密码多一层保障
      "default_mode": "rule"
      // 面板默认显示"规则模式"
      // 对应 clash_mode: rule
      // 可选: rule / direct / global
    },
    "cache_file": {
      // 缓存持久化: 重启后保留FakeIP映射和DNS拒绝记录
      "enabled": true,
      "path": "cache.db",
      // SQLite数据库文件
      "cache_id": "屏蔽的ID",
      // [!] 缓存标识
      // 疑问: cache_id做什么?
      // 回答: 区分不同配置的缓存
      //       切换配置时旧缓存不会污染新配置
      "store_fakeip": true,
      // 保存FakeIP → 域名映射
      // 重启后不需要重新建立FakeIP映射表
      "store_rdrc": true,
      // [+] 新增: 保存DNS拒绝缓存
      // 疑问: RDRC是什么?
      // 回答: Rejected DNS Response Cache
      //       记住"哪些域名被DNS规则reject了"
      //       重启后广告拦截即时生效, 不需要重新查询
      //       否则重启后要重新走一遍DNS规则才能拦截广告
      "rdrc_timeout": "7d"
      // [+] 新增: 7天后过期
      // 广告域名会变化, 定期过期保证准确
    }
  }
}


// ============================================================================
// 附录A: 变更清单
// ============================================================================

// 新增 (6项):
//  [+] DNS服务器:   alidns_doh + alidns_quic + dnspod_doh + dnspod_quic + cfdns_doh
//  [+] DNS规则:     蜂窝→dnspod_quic / WiFi→alidns_doh
//  [+] DNS全局:     client_subnet:"xxx/24"
//  [+] TUN入站:     udp_timeout:"30s"
//  [+] 出站:        pkpk01~05 tcp_fast_open:true
//  [+] 缓存:        store_rdrc:true + rdrc_timeout:"7d"

// 删除 (3项):
//  [-] 路由规则:    cellular→DIRECT(4G全直连 → 代理失效)
//  [-] TUN入站:     sniff_timeout / sniff_override_destination(1.13.0废弃)
//  [-] 路由顶层:    sniff_override_destination / sniff_timeout(不存在)

// 修改 (6项):
//  [*] 日志:        trace → info
//  [*] DNS缓存:     8000 → 65536
//  [*] DNS DoH:     完整URL → 纯主机名 + domain_resolver
//  [*] DNS节点:     占位符"节点域名" → 真实后缀全覆盖
//  [*] 路由:        resolve移到cnip前
//  [*] 规则集:      download_detour PROXY → DIRECT
//  [*] pkpk01:      max_connections→max_streams, 去enabled, 加padding


// ============================================================================
// 附录B: 启动错误排障
// ============================================================================

// 错误1: "missing domain resolver for domain server address"
//   原因: 域名型DNS(alidns_doh等)没有指定解析自身的DNS
//   修复: 所有域名型DNS加 domain_resolver:"alidns_quic"

// 错误2: "parse 'https:%2F%2F...': invalid port"
//   原因: type:"https"的server写了https://前缀 → 双重编码
//   修复: server只写主机名(sing-box自动补全)

// 错误3: "legacy inbound fields deprecated in 1.11.0, removed in 1.13.0"
//   原因: TUN入站有sniff_timeout / sniff_override_destination
//   修复: 删除这两个字段(sniff改为route.rules action:"sniff")

// 错误4: "json: unknown field"
//   原因: route顶层有 sniff_override_destination / sniff_timeout
//         (这些字段不存在于1.13.x的route顶层)
//   修复: 删除

// 错误5: "http2: client connection force closed"
//   原因: 15个规则集同时走PROXY下载 → 并发连接被压断
//   修复: download_detour改为DIRECT, jsdelivr CDN国内可达

// 错误6: pkpk01新配置不通
//   原因: multiplex加了enabled:true → reality不兼容h2mux
//   修复: 去掉enabled(恢复禁用)


// ============================================================================
// 附录C: 关键规则速查
// ============================================================================

// DNS:
//   type:"https"  → server 只填主机名(不要https:// /dns-query)
//   域名型DNS     → 必加 domain_resolver 指向IP型DNS
//   FakeIP        → 零延迟, 但只能用于需要代理的域名

// 路由:
//   resolve       → 放在IP规则集(cnip)之前
//   sniff         → 1.13.0 = route.rules action:"sniff"(不在入站)
//   规则顺序      → 从上到下第一条命中即停, 顺序至关重要

// 节点:
//   reality VLESS → multiplex 不加 enabled
//   WS VLESS      → multiplex enabled:true 正常
//   Naive         → 无 multiplex, 无 tcp_fast_open

// 三网优化:
//   WiFi   → alidns_doh (阿里DoH加密)
//   蜂窝   → dnspod_quic (腾讯UDP低延迟)
//   国外   → ggdns_doh (Google DoH经代理, cfdns_doh备用)
